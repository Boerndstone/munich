{% set url = 'https://www.munichclimbs.de/uploads/areas/' %}
{% set rockMarkers = [] %}
{% for rock in getMainMapRocks() %}
    {# Rock popup: shared template components/map/rock-map-popup.html.twig #}
    {% set rockLink = rock_path(rock.areaSlug, rock.rockSlug) %}
    {% set rockCardArea = {
        routes: rock.amountRoutes|default(0),
        amountEasy: rock.amountEasy|default(0),
        amountMiddle: rock.amountMiddle|default(0),
        amountHard: rock.amountHard|default(0),
        amountProjects: rock.amountProjects|default(0),
        grade_chart_3: rock.grade_chart_3|default(0),
        grade_chart_4: rock.grade_chart_4|default(0),
        grade_chart_5: rock.grade_chart_5|default(0),
        grade_chart_6: rock.grade_chart_6|default(0),
        grade_chart_7: rock.grade_chart_7|default(0),
        grade_chart_8: rock.grade_chart_8|default(0),
        grade_chart_9: rock.grade_chart_9|default(0),
        grade_chart_10: rock.grade_chart_10|default(0),
        grade_chart_11: rock.grade_chart_11|default(0)
    } %}
    {% set popupBody = include('components/area/area-card-body.html.twig', {
        area: rockCardArea,
        ulClass: 'mt-2',
        showTravelTime: false,
        showRocksCount: false,
        aria_label_prefix: 'Klettergebiet ' ~ rock.areaName ~ ', Fels ' ~ rock.rockName ~ '. ',
        compact_chart: true,
        fill_chart_panel: true,
        hide_y_axis: true
    }) %}
    {% set rockPopup %}
{{ include('components/map/rock-map-popup.html.twig', {
	rock: rock,
	areaName: rock.areaName,
	rockLink: rockLink,
	popupBody: popupBody
}) }}
    {% endset %}
    {% set rockMarkers = rockMarkers|merge([{
        'lat': rock.lat,
        'lng': rock.lng,
        'popup': rockPopup|trim,
        'travelTimeMinutes': rock.travelTimeMinutes|default(null)
    }]) %}
{% endfor %}
{% set marker = [] %}
{% for area in getAreasInformation() %}
    {% set popupBody = include('components/area/area-card-body.html.twig', { area: area, ulClass: 'mt-2', showTravelTime: true, chart_summary_include_rocks: true }) %}
    {% set areaName = '<div class="w-[250px] overflow-hidden rounded-t-xl bg-transparent">' ~
        '<div class="relative">' ~
        '<picture><source srcset="' ~ url ~ area.image ~ '@1x.webp 1x, ' ~ url ~ area.image ~ '@2x.webp 2x, ' ~ url ~ area.image ~ '@3x.webp 3x" type="image/webp">' ~
        '<img class="block h-auto w-full rounded-t-xl object-cover object-center" src="' ~ url ~ area.image ~ '.webp" alt="Klettergebiet ' ~ area.name|e('html_attr') ~ '" loading="lazy" decoding="async">' ~
        '</picture>' ~
        '<div class="absolute inset-x-0 top-0 z-10 flex items-center justify-between gap-2 px-3 py-2">' ~
        '<a href="' ~ area_path(area.slug) ~ '" class="inline-block max-w-[calc(100%-3rem)] truncate rounded bg-white/90 px-2 py-1 text-base font-semibold text-gray-900 no-underline shadow-sm dark:bg-slate-900/90 dark:text-white hover:underline">' ~ area.name|e('html') ~ '</a>' ~
        '<button type="button" class="relative z-10 flex size-8 shrink-0 cursor-pointer items-center justify-center rounded-full bg-white/75 text-xl leading-none text-gray-800 shadow-md transition-colors hover:bg-white/90 dark:bg-slate-700/85 dark:text-white dark:hover:bg-slate-600/90 focus:outline-none" onclick="this.closest(\'.leaflet-popup\').querySelector(\'.leaflet-popup-close-button\').click()" aria-label="Schließen"><span class="block leading-none" aria-hidden="true">&times;</span></button>' ~
        '</div></div>' ~
        '<div class="px-3.5 py-3">' ~ popupBody ~ '</div></div>' %}
    {% set areaImage = '' %}
    {% set marker = marker|merge([{
        'lat': area.lat,
        'lng': area.lng,
        'popup': areaName,
        'image': areaImage,
        'travelTimeMinutes': area.travelTimeMinutes|default(null),
        'rocksWithCoordinates': area.rocksWithCoordinates|default(0)
    }]) %}
{% endfor %}

<div 
    class="main-map-container flex min-h-0 flex-1 flex-col"
    data-controller="main-map" 
    data-main-map-markers-value="{{ marker|json_encode|e('html_attr') }}"
    data-main-map-rock-markers-value="{{ rockMarkers|json_encode|e('html_attr') }}"
>
    <div class="main-map-filters shrink-0 px-3 py-2" data-main-map-target="filters" role="group" aria-labelledby="main-map-filter-legend">
        <div class="main-map-filters-scroll">
            <ul class="main-map-filters-list">
                <li id="main-map-filter-legend" class="main-map-filters-label">Entfernung von München:</li>
                <li><button type="button" class="main-map-filter-tab active" data-main-map-target="filterBtn" data-range="all" aria-pressed="true">Alle</button></li>
                <li><button type="button" class="main-map-filter-tab" data-main-map-target="filterBtn" data-range="0-60" aria-pressed="false">&lt; 1 h</button></li>
                <li><button type="button" class="main-map-filter-tab" data-main-map-target="filterBtn" data-range="60-90" aria-pressed="false">1 – 1,5 h</button></li>
                <li><button type="button" class="main-map-filter-tab" data-main-map-target="filterBtn" data-range="120-9999" aria-pressed="false">> 2 h</button></li>
            </ul>
        </div>
    </div>
    <div class="min-h-0 flex-1" data-main-map-target="map" role="region" aria-label="{{ 'index.map_region'|trans({}, 'messages') }}"></div>
</div>
