<picture class="area-lazy-picture">
	{% if suffixes is defined and suffixes is not empty %}
		{% for mediaQuery, suffix in suffixes %}
			<source media="{{ mediaQuery }}" srcset="{{ asset(url ~ area.image ~ '-' ~ suffix ~ '-@1x.webp') }}, {{ asset(url ~ area.image ~ '-' ~ suffix ~ '-@2x.webp') }} 2x, {{ asset(url ~ area.image ~ '-' ~ suffix ~ '-@3x.webp') }} 3x">
		{% endfor %}
	{% else %}
		<source srcset="{{ asset(url ~ area.image ~ '@1x.webp') }}, {{ asset(url ~ area.image ~ '@2x.webp') }} 2x, {{ asset(url ~ area.image ~ '@3x.webp') }} 3x">
	{% endif %}
	<img class="area-lazy-picture__img" src="{{ asset('https://www.munichclimbs.de/uploads/areas/' ~ area.image ~ '.webp') }}" alt="Klettergebiet {{ area.name }}" loading="lazy" decoding="async">
	<span class="badge-opacity area-lazy-picture__badge">
		<h2 class="area-lazy-picture__badge-title">{{ area.name }}</h2>
	</span>
</picture>
