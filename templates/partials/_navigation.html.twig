<header style="height: 50px;">
	<nav class="navbar bg-white fixed-top" style="height: 50px;">
		<div class="container">
			<div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
				<div class="offcanvas-header">
					<a class="offcanvas-title chelsea-market-regular" id="offcanvasNavbarLabel" href="{{path('index')}}">munichclimbs</a>
					<button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
				</div>
				<div class="offcanvas-body">
					<ul class="navbar-nav justify-content-end flex-grow-1 pe-3">
						{% for area in getSidebarAreas() %}
							<li class="nav-item">
								<a class="nav-link d-flex align-items-center" data-bs-toggle="collapse" href="#{{ area.name|custom_replace }}" title="Klettergebiet {{ area.name }}" role="button" aria-expanded="false" aria-controls="{{ area.name|custom_replace }}">
									<img src="https://www.munichclimbs.de/build/images/navigationThumbs/{{ area.image }}.webp" alt="Übersicht Klettergebiete {{ area.name }}." class="rounded me-3" style="width: 18px; height: 18px;" loading="lazy">
									<span class="text-truncate flex-grow-1">{{ area.name }}</span>
									<span class="nav-area-chevron single-chevron-right flex-shrink-0 ms-1" aria-hidden="true"></span>
								</a>
								<div class="collapse" id="{{ area.name|custom_replace }}">
									{% if area.rocks is not empty %}
										<ul class="list-group" style="margin-left: 8px; border-left: 1px solid grey;">
											{% for rock in area.rocks %}
												<li class="list-group-item list-group-item-action d-flex border-0 px-3 py-1 rounded-0">
													<a href="{{ path('show_rock', { 'areaSlug': area.slug, slug: rock.slug } ) }}" title="Link zum Klettergebiet: {{ rock.name }}" class="nav-link py-0 w-100 ms-2" data-area="{{ area.name }}" data-rocks-information="{{ rock.name }}" data-banned="0">{{ rock.name }}</a>
												</li>
											{% endfor %}
										</ul>
									{% endif %}
								</div>
							</li>
						{% endfor %}
						<hr/>
						<li class="nav-item">
							<a class="nav-link d-flex align-items-center" href="{{ path('app_suche') }}" title="Suche nach Erstbegeher">
								<div class="magnifier d-inline-block me-3"></div>
								<span class="text-truncate">Suche</span>
							</a>
						</li>
						<hr/>
						<li class="nav-item">
							<a class="nav-link d-flex align-items-center" href="{{ path('app_login') }}" title="Login">
								<div class="user d-inline-block me-3"></div>
								<span class="text-truncate">Login</span>
							</a>
						</li>
						<hr/>
						<li class="nav-item">
							<div class="nav-link text-truncate">Kontakt</div>
						</li>
						<li class="nav-item">
							<a class="nav-link d-flex align-items-center" href="{{ path('datenschutz') }}">
								<div class="chart d-inline-block me-3"></div>
								<span class="text-truncate">Datenschutz</span>
							</a>
						</li>
						{# <li class="nav-item">
							<a class="nav-link d-flex align-items-center" href="{{ path('upload_photo') }}" title="Foto hochladen">
								<div class="chart d-inline-block me-3"></div>
								<div class="text-truncate">Foto hochladen</div>
							</a>
						</li> #}
						<li class="nav-item">
							<a class="nav-link d-flex align-items-center" href="{{ path('impressum') }}">
								<div class="chart d-inline-block me-3"></div>
								<div class="text-truncate">Impressum</div>
							</a>
						</li>
						<hr/>
						<li class="nav-item">
							<div class="nav-link text-truncate">Theme Mode</div>
						</li>
						<li class="nav-item d-flex align-items-center" data-controller="theme">
							<button type="button" class="theme-toggle-btn" data-action="click->theme#cycle" aria-label="Toggle theme" title="Theme wechseln (System → Hell → Dunkel)">
								<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-toggle-icon" aria-hidden="true">
									<path stroke="none" d="M0 0h24v24H0z" fill="none"/>
									<path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/>
									<path d="M12 3l0 18"/>
									<path d="M12 9l4.65 -4.65"/>
									<path d="M12 14.3l7.37 -7.37"/>
									<path d="M12 19.6l8.85 -8.85"/>
								</svg>
								<span class="visually-hidden">Toggle theme</span>
							</button>
						</li>
					</ul>
				</div>
			</div>
			<div class="container p-0">
				<div class="row">
					<div class="col-1 col-md-3 d-flex align-items-center">
						<button class="navbar-toggler p-0 bg-none border-0 shadow-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar" aria-label="Toggle navigation">
							<div class="menu"></div>
						</button>
						<a href="{{path('index')}}" aria-label="Startseite munichclimbs" class="munich pb-lg-1 fs-5 ms-3 chelsea-market-regular">
							<span class="d-none d-md-inline-block">munichclimbs</span>
						</a>
					</div>
					<div class="{% if app.request.attributes.get('_route') == 'show_rock' and hasTranslationDescription is defined and hasTranslationDescription or app.request.attributes.get('_route') == 'show_rock_en' and hasTranslationDescription is defined and hasTranslationDescription %}col-9 col-md-8{% else %}col-11 col-md-9{% endif %}">
						<form class="w-100 mb-0">
							<div data-controller="autocomplete" data-autocomplete-url-value="/search" style="position: relative;">
								<div class="d-flex">
									<!-- Left side: Search input -->
									<div class="position-relative flex-grow-1">
										<i class="fas fa-search magnifier position-absolute" style="left: 10px; top: 50%; transform: translateY(-50%); z-index: 10; color: #6c757d;"></i>
										<input data-autocomplete-target="input" data-action="input->autocomplete#search" name="q" placeholder="Suche nach Felsen oder Routen..." type="search" class="form-control form-control-sm border-black text-black w-100" style="padding-left: 35px; border-top-right-radius: 0; border-bottom-right-radius: 0; border-right: none;" aria-label="Suche nach Felsen oder Routen">
									</div>
									
									<!-- Right side: Search mode selector -->
									<select data-autocomplete-target="searchMode" class="form-select form-select-sm border-black" style="width: 100px; font-size: 11px; border-top-left-radius: 0; border-bottom-left-radius: 0; border-left: none; box-shadow: none;" aria-label="Suchmodus auswählen">
										<option value="name">Route/Fels</option>
										<option value="firstascent">Erstbegeher</option>
									</select>
								</div>
								<ul class="list-group" data-autocomplete-target="results" style="display: block; position: absolute; width: 100%;"></ul>
							</div>
						</form>
					</div>
					<div class="{% if app.request.attributes.get('_route') == 'show_rock' and hasTranslationDescription is defined and hasTranslationDescription or app.request.attributes.get('_route') == 'show_rock_en' and hasTranslationDescription is defined and hasTranslationDescription %}col-2{% else %}col-2{% endif %} col-md-1 d-flex justify-content-end">
						{% if app.request.attributes.get('_route') == 'show_rock' and hasTranslationDescription is defined and hasTranslationDescription or app.request.attributes.get('_route') == 'show_rock_en' and hasTranslationDescription is defined and hasTranslationDescription  %}
							{{ include('partials/_language_switch.html.twig', { 
								hasTranslationDescription: hasTranslationDescription,
								areaSlug: app.request.attributes.get('areaSlug'),
								rockSlug: app.request.attributes.get('slug')
							}) }}
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</nav>
</header>
