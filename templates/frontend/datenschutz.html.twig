{% extends 'base.html.twig' %}

{% block title %}{{ 'legal.datenschutz_page_title'|trans }}{% endblock %}

{% block body %}
	{{ include('components/layout/navigation.html.twig') }}
	<main id="main-content">
		<div class="mx-auto my-4 w-full max-w-[1024px] px-2 sm:px-4">
			<section>
				<div class="mb-3 flex items-center justify-between py-3">
					<h1 class="mb-0 text-3xl font-medium leading-tight text-gray-900 dark:text-gray-100">{{ 'legal.datenschutz_h1'|trans }}</h1>
				</div>
			</section>
			<section class="max-w-3xl space-y-5 text-sm leading-relaxed text-gray-800 [&_a]:break-words [&_a]:text-sky-700 [&_a]:underline-offset-2 [&_a]:hover:underline dark:text-gray-200 dark:[&_a]:text-sky-400">
				{% include app.locale == 'en' ? 'frontend/datenschutz_content.en.html.twig' : 'frontend/datenschutz_content.de.html.twig' %}
			</section>
		</div>
	</main>
{% endblock %}
