<div class="overflow-hidden rounded-lg border-b border-gray-200 border-l border-r border-t border-sky-800 bg-white shadow-md dark:border-b-gray-700 dark:border-l-sky-700 dark:border-r-sky-700 dark:border-t-sky-700 dark:bg-black">
	<h3 class="mb-0 bg-sky-800 px-3 py-2 text-lg font-light leading-normal text-white dark:bg-sky-900">{{ 'home.latest_routes_title'|trans }}</h3>
	<ul class="my-2 list-none px-0">
		{% for latestRoute in latestRoutes %}
			<li class="mb-2">
				<a class="flex items-start gap-x-2 px-2 py-1 leading-[1.3rem] text-black no-underline hover:bg-gray-200 dark:text-white dark:hover:bg-gray-800" href="{{ rock_path(latestRoute.areaSlug, latestRoute.rockSlug) }}">
					<span class="w-4 shrink-0 select-none pt-0.5 text-center text-base leading-none text-sky-800 pe-1 dark:text-sky-400" aria-hidden="true">&#8226;</span>
					<span class="min-w-0 flex-1">
						<span class="block truncate text-sm font-normal text-gray-900 dark:text-gray-100">{{ latestRoute.name }} {{ latestRoute.grade }}</span>
						<span class="block truncate ps-0 text-sm font-light text-gray-900 dark:text-gray-100">{{ latestRoute.rockName }}</span>
					</span>
				</a>
			</li>
		{% endfor %}
	</ul>
	<hr class="my-2 border-0 border-t border-dotted border-gray-300 dark:border-gray-600">
	<a class="flex items-center px-2 pb-2 text-sm font-semibold text-sky-800 no-underline hover:underline dark:text-sky-400" href="{{ path(app.request.locale == 'en' ? 'neuesteRouten_en' : 'neuesteRouten') }}">
		<span class="chevron-right" aria-hidden="true"></span>{{ 'home.latest_routes_more'|trans }}
	</a>
</div>
