{# Search dialog — opened from nav (search-modal#open) #}
<dialog
	id="searchModal"
	class="search-modal-dialog z-[10560] overflow-hidden rounded-lg bg-white text-gray-900 shadow-xl dark:bg-gray-900 dark:text-gray-100"
	aria-labelledby="searchModalLabel"
	aria-modal="true"
	data-search-modal-target="modal"
	onclick="if (event.target === this) this.close()"
>
	<div class="flex max-h-[min(90vh,720px)] min-h-0 flex-col" onclick="event.stopPropagation()">
		<div class="flex shrink-0 items-center justify-between border-b border-gray-200 px-3 py-2 dark:border-gray-700">
			<h2 class="mb-0 text-base font-semibold text-gray-900 dark:text-gray-100" id="searchModalLabel">Suche</h2>
			<button type="button" class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md text-gray-600 hover:bg-gray-100 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-gray-400 dark:text-gray-300 dark:hover:bg-gray-800" data-action="click->search-modal#close" aria-label="Schließen">
				<span class="sr-only">Schließen</span>
				<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
				</svg>
			</button>
		</div>
		<div class="min-h-0 flex-1 overflow-y-auto p-3">
			<ul class="mb-3 flex list-none flex-nowrap gap-1 overflow-x-auto rounded-lg bg-gray-100 p-1 dark:bg-gray-800" id="searchTabs" role="tablist">
				<li class="shrink-0" role="presentation">
					<button class="rounded-md border border-black bg-white px-2 py-1 text-sm text-black dark:border-gray-300 dark:bg-gray-900 dark:text-gray-100" id="tab-name" type="button" role="tab" aria-selected="true" data-search-tab="name">Route/Fels</button>
				</li>
				<li class="shrink-0" role="presentation">
					<button class="rounded-md border border-transparent bg-transparent px-2 py-1 text-sm text-gray-600 hover:bg-white/80 dark:text-gray-400 dark:hover:bg-gray-700/80" id="tab-firstascent" type="button" role="tab" aria-selected="false" data-search-tab="firstascent">Erstbegeher</button>
				</li>
				<li class="shrink-0" role="presentation">
					<button class="rounded-md border border-transparent bg-transparent px-2 py-1 text-sm text-gray-600 hover:bg-white/80 dark:text-gray-400 dark:hover:bg-gray-700/80" id="tab-grade" type="button" role="tab" aria-selected="false" data-search-tab="grade">Grad</button>
				</li>
				<li class="shrink-0" role="presentation">
					<button class="rounded-md border border-transparent bg-transparent px-2 py-1 text-sm text-gray-600 hover:bg-white/80 dark:text-gray-400 dark:hover:bg-gray-700/80" id="tab-attributes" type="button" role="tab" aria-selected="false" data-search-tab="attributes">Eigenschaften</button>
				</li>
			</ul>

			<div id="pane-name" class="search-tab-panel mb-4" role="tabpanel">
				<label for="searchModalNameInput" class="sr-only">Suche nach Felsen oder Routen</label>
				<div class="flex items-center rounded-md border border-black bg-white px-2 py-1.5 text-sm dark:border-gray-500 dark:bg-gray-950">
					<i class="fas fa-search magnifier me-2 shrink-0 text-gray-500" aria-hidden="true"></i>
					<input type="search" id="searchModalNameInput" class="min-w-0 flex-1 border-0 bg-transparent p-0 text-sm text-black placeholder:text-gray-500 focus:ring-0 dark:text-gray-100" name="searchName" data-search-modal-target="nameInput" placeholder="Suche nach Felsen oder Routen..." data-action="input->search-modal#searchNameDebounced keydown.enter->search-modal#searchName" minlength="2">
				</div>
			</div>
			<div id="pane-firstascent" class="search-tab-panel mb-4 hidden" role="tabpanel">
				<label for="searchModalFirstAscentInput" class="sr-only">Name des Erstbegehers</label>
				<div class="flex items-center rounded-md border border-black bg-white px-2 py-1.5 text-sm dark:border-gray-500 dark:bg-gray-950">
					<i class="fas fa-search magnifier me-2 shrink-0 text-gray-500" aria-hidden="true"></i>
					<input type="search" id="searchModalFirstAscentInput" class="min-w-0 flex-1 border-0 bg-transparent p-0 text-sm focus:ring-0 dark:text-gray-100" data-search-modal-target="firstAscentInput" placeholder="Name des Erstbegehers..." data-action="input->search-modal#searchFirstAscentDebounced keydown.enter->search-modal#searchFirstAscent" minlength="2">
				</div>
			</div>
			<div id="pane-grade" class="search-tab-panel mb-4 hidden" role="tabpanel">
				<div class="mb-3 grid grid-cols-1 gap-3 md:grid-cols-2">
					<div>
						<label class="mb-1 block text-xs font-medium text-gray-700 dark:text-gray-300" for="searchModalGradeAreaSelect">Gebiet</label>
						<select id="searchModalGradeAreaSelect" class="block w-full rounded-md border border-gray-300 bg-white px-2 py-1.5 text-sm dark:border-gray-600 dark:bg-gray-950 dark:text-gray-100" data-search-modal-target="areaSelect">
							<option value="">Alle Gebiete</option>
							{% for area in getSidebarAreas() %}
								<option value="{{ area.slug }}">{{ area.name }}</option>
							{% endfor %}
						</select>
					</div>
					<div class="md:col-span-2">
						<fieldset class="m-0 border-0 p-0">
							<legend class="mb-2 w-auto p-0 text-xs font-medium text-gray-700 dark:text-gray-300">Schwierigkeitsgrade</legend>
							<div class="flex flex-wrap gap-3">
								{% for i in 1..11 %}
									<label class="inline-flex cursor-pointer items-center gap-1.5 text-sm">
										<input class="size-4 rounded border-gray-400 text-black focus:ring-gray-500 dark:border-gray-600" type="checkbox" data-search-modal-target="gradeCheck" value="{{ i }}" id="searchGrade{{ i }}">
										<span>{{ i }}</span>
									</label>
								{% endfor %}
							</div>
						</fieldset>
					</div>
					<div class="md:col-span-2">
						<button class="inline-flex items-center gap-1 rounded-md border border-gray-600 bg-white px-3 py-1.5 text-sm font-medium text-gray-800 hover:bg-gray-50 dark:border-gray-500 dark:bg-gray-900 dark:text-gray-100 dark:hover:bg-gray-800" type="button" data-action="click->search-modal#searchByGrade">
							<i class="fas fa-search" aria-hidden="true"></i>Nach Schwierigkeit suchen
						</button>
					</div>
				</div>
			</div>
			<div id="pane-attributes" class="search-tab-panel mb-4 hidden" role="tabpanel">
				<div class="mb-3 grid grid-cols-1 gap-3 md:grid-cols-2">
					<div>
						<label class="mb-1 block text-xs font-medium text-gray-700 dark:text-gray-300" for="searchModalAttributesAreaSelect">Gebiet</label>
						<select id="searchModalAttributesAreaSelect" class="block w-full rounded-md border border-gray-300 bg-white px-2 py-1.5 text-sm dark:border-gray-600 dark:bg-gray-950 dark:text-gray-100" data-search-modal-target="areaSelectAttributes">
							<option value="">Alle Gebiete</option>
							{% for area in getSidebarAreas() %}
								<option value="{{ area.slug }}">{{ area.name }}</option>
							{% endfor %}
						</select>
					</div>
					<div class="md:col-span-2">
						<fieldset class="m-0 border-0 p-0">
							<legend class="mb-2 w-auto p-0 text-xs font-medium text-gray-700 dark:text-gray-300">Eigenschaften</legend>
							<div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
								<label class="inline-flex cursor-pointer items-center gap-2 text-sm">
									<input class="size-4 rounded border-gray-400 text-black focus:ring-gray-500" type="checkbox" data-search-modal-target="attrChildFriendly" value="1" id="searchAttrChildFriendly">
									<span class="child-friendly" aria-hidden="true"></span>
									{{ "child.friendly"|trans }}
								</label>
								<label class="inline-flex cursor-pointer items-center gap-2 text-sm">
									<input class="size-4 rounded border-gray-400 text-black focus:ring-gray-500" type="checkbox" data-search-modal-target="attrSunny" value="1" id="searchAttrSunny">
									<span class="sun" aria-hidden="true"></span>
									{{ "sunny"|trans }}
								</label>
								<label class="inline-flex cursor-pointer items-center gap-2 text-sm">
									<input class="size-4 rounded border-gray-400 text-black focus:ring-gray-500" type="checkbox" data-search-modal-target="attrRainProtected" value="1" id="searchAttrRainProtected">
									<span class="umbrella" aria-hidden="true"></span>
									{{ "rain.proof"|trans }}
								</label>
								<label class="inline-flex cursor-pointer items-center gap-2 text-sm">
									<input class="size-4 rounded border-gray-400 text-black focus:ring-gray-500" type="checkbox" data-search-modal-target="attrTrain" value="1" id="searchAttrTrain">
									<span class="train" aria-hidden="true"></span>
									{{ "train.reachable"|trans }}
								</label>
								<label class="inline-flex cursor-pointer items-center gap-2 text-sm">
									<input class="size-4 rounded border-gray-400 text-black focus:ring-gray-500" type="checkbox" data-search-modal-target="attrBike" value="1" id="searchAttrBike">
									<span class="bike" aria-hidden="true"></span>
									{{ "bike.reachable"|trans }}
								</label>
							</div>
						</fieldset>
					</div>
					<div class="md:col-span-2">
						<button class="inline-flex items-center gap-1 rounded-md border border-gray-600 bg-white px-3 py-1.5 text-sm font-medium text-gray-800 hover:bg-gray-50 dark:border-gray-500 dark:bg-gray-900 dark:text-gray-100 dark:hover:bg-gray-800" type="button" data-action="click->search-modal#searchByAttributes">
							<i class="fas fa-search" aria-hidden="true"></i>Nach Eigenschaften suchen
						</button>
					</div>
				</div>
			</div>

			<div data-search-modal-target="resultsContainer" class="hidden border-t border-gray-200 pt-3 dark:border-gray-700">
				<h3 class="mb-2 text-sm font-semibold text-gray-900 dark:text-gray-100"><span data-search-modal-target="resultsCount">0</span> Ergebnisse</h3>
				<div data-search-modal-target="rocksSection" class="mb-3 hidden">
					<div class="mb-1 text-sm font-bold text-gray-800 dark:text-gray-200">Felsen</div>
					<ul class="m-0 list-none rounded-md border border-gray-200 p-0 dark:border-gray-700" data-search-modal-target="rocksList"></ul>
				</div>
				<hr class="my-2 border-gray-200 dark:border-gray-700" />
				<div data-search-modal-target="routesSection" class="hidden">
					<div class="mb-2 text-sm font-bold text-gray-800 dark:text-gray-200">Touren</div>
					<div class="mb-2 flex flex-wrap gap-2 px-1 text-xs font-bold text-gray-700 dark:text-gray-300">
						<span class="w-[40%] min-w-0 sm:w-2/5">Route</span>
						<span class="w-8 shrink-0 sm:w-12">Grad</span>
						<span class="min-w-0 flex-1">Fels</span>
						<span class="hidden w-1/4 sm:inline-block">Gebiet</span>
					</div>
					<ul class="m-0 list-none p-0" data-search-modal-target="routesTable"></ul>
					<div data-search-modal-target="pagerContainer" class="mt-2 hidden flex-wrap items-center justify-between gap-2">
						<button type="button" class="inline-flex items-center gap-1 rounded-md border border-gray-600 bg-white px-2 py-1 text-sm dark:border-gray-500 dark:bg-gray-900 dark:text-gray-100" data-search-modal-target="pagerPrev" data-action="click->search-modal#gradePagePrev" aria-label="Vorherige Seite">
							<i class="fas fa-chevron-left" aria-hidden="true"></i>Zurück
						</button>
						<span class="text-xs text-gray-600 dark:text-gray-400" data-search-modal-target="pagerInfo">Seite 1 von 1</span>
						<button type="button" class="inline-flex items-center gap-1 rounded-md border border-gray-600 bg-white px-2 py-1 text-sm dark:border-gray-500 dark:bg-gray-900 dark:text-gray-100" data-search-modal-target="pagerNext" data-action="click->search-modal#gradePageNext" aria-label="Nächste Seite">
							Weiter<i class="fas fa-chevron-right ms-1" aria-hidden="true"></i>
						</button>
					</div>
				</div>
				<div data-search-modal-target="emptyState" class="hidden text-sm text-gray-500 dark:text-gray-400">Keine Ergebnisse gefunden.</div>
			</div>
		</div>
	</div>
</dialog>
