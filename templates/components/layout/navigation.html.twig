<header class="fixed top-0 z-[1045] h-[50px] w-full border-b border-[var(--theme-border)] bg-[var(--theme-bg)] text-[var(--theme-text)] transition-colors">
	<nav class="mx-auto flex h-full max-w-[1024px] items-stretch px-2" aria-label="Hauptnavigation">
		<dialog
			id="navOffcanvas"
			class="nav-offcanvas-dialog z-[1055]"
			aria-labelledby="navOffcanvasTitle"
			aria-modal="true"
		>
			<div class="flex h-full min-h-0 w-full">
				<div class="flex h-full min-h-0 w-[min(100vw,20rem)] max-w-full flex-col overflow-y-auto bg-[var(--theme-bg)] shadow-xl" onclick="event.stopPropagation()">
					<div class="flex shrink-0 items-center justify-between border-b border-[var(--theme-border)] px-3 py-2">
						<a class="chelsea-market-regular text-lg text-[var(--theme-text)] no-underline" id="navOffcanvasTitle" href="{{ path('index') }}">munichclimbs</a>
						<button type="button" class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md text-[var(--theme-text)] opacity-70 hover:bg-[var(--theme-bg-lighter)] hover:opacity-100 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-[var(--theme-border)]" onclick="document.getElementById('navOffcanvas').close()" aria-label="{{ 'close_navigation'|trans({}, 'messages') }}">
							<span class="sr-only">{{ 'close_navigation'|trans({}, 'messages') }}</span>
							<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
							</svg>
						</button>
					</div>
					<div class="min-h-0 flex-1 overflow-y-auto pe-2 ps-1 mt-2">
						{% set _route = app.request.attributes.get('_route') %}
						{% set currentAreaSlug = _route == 'show_rock' or _route == 'show_rock_en' ? app.request.attributes.get('areaSlug') : (_route == 'show_rocks' ? app.request.attributes.get('slug') : null) %}
						{% set currentRockSlug = (_route == 'show_rock' or _route == 'show_rock_en') ? app.request.attributes.get('slug') : null %}
						<ul class="m-0 list-none p-0">
							{% for area in getSidebarAreas() %}
								{% set isCurrentArea = currentAreaSlug and area.slug == currentAreaSlug %}
								<li>
									<details class="group" {{ isCurrentArea ? 'open' : '' }}>
										<summary class="flex cursor-pointer list-none items-center gap-2 px-2 py-2 text-sm text-gray-900 marker:hidden [&::-webkit-details-marker]:hidden dark:text-gray-100">
											<img src="https://www.munichclimbs.de/build/images/navigationThumbs/{{ area.image }}.webp" alt="" class="size-[18px] shrink-0 rounded" loading="lazy">
											<span class="min-w-0 flex-1 truncate">{{ area.name }}</span>
											<span class="nav-area-chevron single-chevron-right ms-1 shrink-0 transition-transform duration-200 ease-out" aria-hidden="true"></span>
										</summary>
										{% if area.rocks is not empty %}
											<ul class="m-0 list-none border-l border-gray-300 py-1 ps-2 dark:border-gray-600" style="margin-left: 8px;">
												{% for rock in area.rocks %}
													{% set isCurrentRock = isCurrentArea and currentRockSlug and rock.slug == currentRockSlug %}
													<li class="rounded px-1 py-0.5 {{ isCurrentRock ? 'bg-black text-white' : '' }}">
														<a href="{{ path('show_rock', { 'areaSlug': area.slug, slug: rock.slug }) }}" title="Link zum Klettergebiet: {{ rock.name }}" class="block w-full truncate py-1 ps-2 text-sm no-underline {{ isCurrentRock ? 'text-white' : 'text-gray-800 dark:text-gray-200' }}" data-area="{{ area.name }}" data-rocks-information="{{ rock.name }}" data-banned="0">{{ rock.name }}</a>
													</li>
												{% endfor %}
											</ul>
										{% endif %}
									</details>
								</li>
							{% endfor %}
						</ul>
						<hr class="my-2 border-gray-200 dark:border-gray-700" />
						<ul class="m-0 list-none p-0 pb-4">
							<li>
								<a class="flex items-center gap-2 px-2 py-2 text-sm text-gray-900 no-underline hover:bg-gray-50 dark:text-gray-100 dark:hover:bg-gray-800" href="{{ path('app_login') }}" title="Login">
									<span class="user inline-block shrink-0" aria-hidden="true"></span>
									<span class="truncate">Login</span>
								</a>
							</li>
							<li>
								<div class="truncate px-2 py-2 text-sm text-gray-600 dark:text-gray-400">Kontakt</div>
							</li>
							<li>
								<a class="flex items-center gap-2 px-2 py-2 text-sm text-gray-900 no-underline hover:bg-gray-50 dark:text-gray-100 dark:hover:bg-gray-800" href="{{ path('datenschutz') }}">
									<span class="chart inline-block shrink-0" aria-hidden="true"></span>
									<span class="truncate">Datenschutz</span>
								</a>
							</li>
							<li>
								<a class="flex items-center gap-2 px-2 py-2 text-sm text-gray-900 no-underline hover:bg-gray-50 dark:text-gray-100 dark:hover:bg-gray-800" href="{{ path('impressum') }}">
									<span class="chart inline-block shrink-0" aria-hidden="true"></span>
									<span class="truncate">Impressum</span>
								</a>
							</li>
							<li>
								<a class="flex items-center gap-2 px-2 py-2 text-sm text-gray-900 no-underline hover:bg-gray-50 dark:text-gray-100 dark:hover:bg-gray-800" href="{{ path(app.request.locale == 'en' ? 'free_climbing_grade_comparison_en' : 'free_climbing_grade_comparison') }}">
									<span class="chart inline-block shrink-0" aria-hidden="true"></span>
									<span class="truncate">{{ 'grade_comparison_free_climbing.nav_link'|trans }}</span>
								</a>
							</li>
						</ul>
					</div>
				</div>
				<button type="button" class="min-h-0 min-w-0 flex-1 cursor-default border-0 bg-black/40 p-0" aria-label="{{ 'close_navigation'|trans({}, 'messages') }}" onclick="document.getElementById('navOffcanvas').close()"></button>
			</div>
		</dialog>
		<div class="flex w-full max-w-[1024px] flex-1 items-center gap-2 px-0">
			<div class="flex shrink-0 items-center gap-1 ps-0 md:w-1/4 md:gap-2 md:ps-1">
				<button class="inline-flex shrink-0 border-0 bg-transparent p-0 shadow-none focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-[var(--theme-border)]" type="button" onclick="document.getElementById('navOffcanvas').showModal()" aria-controls="navOffcanvas" aria-label="Toggle navigation">
					<div class="menu" aria-hidden="true"></div>
				</button>
				<a href="{{ path('index') }}" aria-label="Startseite munichclimbs" class="munich chelsea-market-regular ms-2 pb-1 text-xl leading-tight no-underline">
					<span class="max-md:hidden md:inline-block">munichclimbs</span>
				</a>
			</div>
			<div class="min-w-0 flex-1 {% if app.request.attributes.get('_route') == 'show_rock' and hasTranslationDescription is defined and hasTranslationDescription or app.request.attributes.get('_route') == 'show_rock_en' and hasTranslationDescription is defined and hasTranslationDescription %}md:w-7/12{% else %}md:w-2/3{% endif %}">
				<div class="flex cursor-pointer items-center rounded-md border border-[var(--theme-border)] bg-[var(--theme-bg-lighter)] px-2 py-1.5 text-sm text-[var(--theme-text)] shadow-sm focus-within:ring-2 focus-within:ring-[var(--theme-border)]" data-action="click->search-modal#open keydown.enter->search-modal#open" role="button" tabindex="0" aria-label="Suche öffnen">
					<i class="fas fa-search magnifier me-2 shrink-0 opacity-60" aria-hidden="true"></i>
					<span class="truncate opacity-80">Suche</span>
				</div>
			</div>
			{% set _showLang = (app.request.attributes.get('_route') == 'show_rock' and hasTranslationDescription is defined and hasTranslationDescription) or (app.request.attributes.get('_route') == 'show_rock_en' and hasTranslationDescription is defined and hasTranslationDescription) %}
			<div class="{{ _showLang ? 'flex w-10 shrink-0 items-center justify-end sm:w-12' : 'hidden' }}">
				{% if _showLang %}
					{{ include('components/layout/language-switch.html.twig', {
						hasTranslationDescription: hasTranslationDescription,
						areaSlug: app.request.attributes.get('areaSlug'),
						rockSlug: app.request.attributes.get('slug')
					}) }}
				{% endif %}
			</div>
			<div class="flex shrink-0 justify-end ps-1" data-controller="theme">
				<button type="button" class="theme-toggle-btn inline-flex shrink-0 rounded-md border-0 bg-transparent p-1 text-[var(--theme-text)] focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-[var(--theme-border)]" data-action="click->theme#cycle" aria-label="Toggle theme" title="Theme wechseln (System → Hell → Dunkel)">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-toggle-icon" aria-hidden="true">
						<path stroke="none" d="M0 0h24v24H0z" fill="none"/>
						<path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/>
						<path d="M12 3l0 18"/>
						<path d="M12 9l4.65 -4.65"/>
						<path d="M12 14.3l7.37 -7.37"/>
						<path d="M12 19.6l8.85 -8.85"/>
					</svg>
					<span class="sr-only">Toggle theme</span>
				</button>
			</div>
		</div>
	</nav>
</header>
