{# Expects: setTitle, areaName, areaImage, areaKletterkonzeption (truthy), top100Routes (iterable) #}
<div class="image-container">
	<div class="image-container-media">
		{% if areaImage is not empty %}
			<picture>
				<source media="(min-width: 1200px)" srcset="{{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-large-@1x.webp') }}, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-large-@2x.webp') }} 2x, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-large-@3x.webp') }} 3x">
				<source media="(min-width: 800px)" srcset="{{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-medium-@1x.webp') }}, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-medium-@2x.webp') }} 2x, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-medium-@3x.webp') }} 3x">
				<img src="{{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-small-@1x.webp') }}" srcset="{{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-small-@2x.webp') }} 2x, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-small-@3x.webp') }} 3x" alt="{{ setTitle }}" fetchpriority="high" decoding="async">
			</picture>
		{% else %}
			<div class="h-[100px]"></div>
		{% endif %}
	</div>
	<div class="absolute inset-x-0 top-0 z-[1] mx-auto my-3 w-full max-w-[1024px] px-2 sm:px-4">
		<div class="rounded pb-3 sm:pb-4">
			<div class="flex min-w-0 items-center justify-between gap-3 rounded-md bg-white/60 p-3 shadow-md ring-1 ring-black/5 dark:bg-white/50 dark:ring-white/10">
				<div class="flex min-w-0 flex-1 items-center">
					<h1 class="stay-black mb-0 min-w-0 text-2xl font-medium sm:text-3xl">
						{{ areaName }}
					</h1>
				</div>
				<div class="flex shrink-0 items-center">
					<details id="areaHeroMoreMenu" class="group relative">
						<summary class="inline-flex list-none cursor-pointer items-center rounded-md border border-border bg-background px-2.5 py-1 text-sm font-medium text-foreground shadow-xs outline-none hover:bg-muted focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden" aria-label="Weitere Informationen">
							<div class="modal-info shrink-0 bg-center bg-no-repeat" style="width: 22px; height: 22px;" aria-hidden="true"></div>
						</summary>
						<div class="absolute end-0 z-[1080] mt-1 min-w-[12rem] rounded-md border border-border bg-popover p-1 text-popover-foreground shadow-md outline-none" role="menu" aria-orientation="vertical">
							<ul class="m-0 list-none p-0">
								{% if areaKletterkonzeption %}
									<li role="none">
										<button type="button" class="flex w-full cursor-pointer items-center gap-2 rounded-sm border-0 bg-transparent px-2 py-1.5 text-left text-sm text-foreground outline-none hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground" role="menuitem" onclick="document.getElementById('areaHeroMoreMenu').removeAttribute('open'); document.getElementById('kletterkonzeptionModal').showModal()">
											<span class="modal-info shrink-0 bg-center bg-no-repeat" style="width: 22px; height: 22px;" aria-hidden="true"></span>
											Kletterkonzeption - {{ areaName }}
										</button>
									</li>
								{% endif %}
								{% if top100Routes is not empty %}
									<li role="none">
										<button type="button" class="flex w-full cursor-pointer items-center gap-2 rounded-sm border-0 bg-transparent px-2 py-1.5 text-left text-sm text-foreground outline-none hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground" role="menuitem" onclick="document.getElementById('areaHeroMoreMenu').removeAttribute('open'); document.getElementById('top100RoutesModal').showModal()">
											<span class="top-100 shrink-0" aria-hidden="true"></span>
											Top 100 - {{ areaName }}
										</button>
									</li>
								{% endif %}
								<li role="none">
									<button type="button" class="flex w-full cursor-pointer items-center gap-2 rounded-sm border-0 bg-transparent px-2 py-1.5 text-left text-sm text-foreground outline-none hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground" role="menuitem" onclick="document.getElementById('areaHeroMoreMenu').removeAttribute('open'); document.getElementById('modalWeather').showModal()">
										<span class="weather shrink-0" aria-hidden="true"></span>
										Wetter
									</button>
								</li>
								<li role="none">
									<button type="button" class="flex w-full cursor-pointer items-center gap-2 rounded-sm border-0 bg-transparent px-2 py-1.5 text-left text-sm text-foreground outline-none hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground" role="menuitem" onclick="document.getElementById('areaHeroMoreMenu').removeAttribute('open'); document.getElementById('modalAreaMap').showModal()">
										<span class="map shrink-0" aria-hidden="true"></span>
										Übersichtskarte {{ areaName }}
									</button>
								</li>
							</ul>
						</div>
					</details>
				</div>
			</div>
		</div>
	</div>
</div>
