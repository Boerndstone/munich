{# Expects: setTitle, areaName, areaImage, areaKletterkonzeption (truthy), top100Routes (iterable) #}
<div class="image-container">
	<div class="image-container-media">
		{% if areaImage is not empty %}
			<picture>
				<source media="(min-width: 1200px)" srcset="{{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-large-@1x.webp') }}, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-large-@2x.webp') }} 2x, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-large-@3x.webp') }} 3x">
				<source media="(min-width: 800px)" srcset="{{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-medium-@1x.webp') }}, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-medium-@2x.webp') }} 2x, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-medium-@3x.webp') }} 3x">
				<img src="{{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-small-@1x.webp') }}" srcset="{{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-small-@2x.webp') }} 2x, {{ asset('https://www.munichclimbs.de/uploads/header/' ~ areaImage ~ '-small-@3x.webp') }} 3x" alt="{{ setTitle }}" fetchpriority="high" decoding="async">
			</picture>
		{% else %}
			<div class="h-[100px]"></div>
		{% endif %}
	</div>
	<div class="container absolute inset-x-0 top-0 z-[1] mx-auto my-3">
		<div class="rounded pb-3">
			<div class="flex items-center justify-between rounded bg-white/60 p-3 shadow-lg ring-1 ring-black/5 dark:bg-white/50 dark:ring-white/10">
				<div class="flex items-center">
					<h1 class="stay-black mb-0 mr-2 text-2xl font-medium sm:text-3xl">
						{{ areaName }}
					</h1>
				</div>
				<div class="flex items-center">
					<div class="dropdown relative">
						<button class="dropdown-toggle inline-flex items-center rounded-md border border-gray-400 bg-white px-2.5 py-1 text-sm font-medium text-gray-800 shadow-xs hover:bg-gray-100 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-gray-400 dark:border-gray-500 dark:text-gray-100 dark:hover:bg-gray-800" type="button" data-bs-toggle="dropdown" data-bs-popper-config='{"strategy":"fixed"}' data-bs-auto-close="true" aria-expanded="false" aria-haspopup="true" aria-label="Weitere Informationen">
							<div class="modal-info"></div>
						</button>
						<ul class="dropdown-menu dropdown-menu-end z-[1080] min-w-[12rem] rounded-lg border border-gray-200 bg-white py-1 shadow-lg dark:border-gray-700 dark:bg-gray-900">
							{% if areaKletterkonzeption %}
								<li>
									<button type="button" class="dropdown-item flex w-full items-center px-4 py-2 text-left text-sm text-gray-900 hover:bg-gray-100 dark:text-gray-100 dark:hover:bg-gray-800" data-bs-toggle="modal" data-bs-target="#kletterkonzeptionModal"><span class="modal-info mr-2 shrink-0"></span> Kletterkonzeption - {{ areaName }}</button>
								</li>
							{% endif %}
							{% if top100Routes is not empty %}
								<li>
									<button type="button" class="dropdown-item flex w-full items-center px-4 py-2 text-left text-sm text-gray-900 hover:bg-gray-100 dark:text-gray-100 dark:hover:bg-gray-800" data-bs-toggle="modal" data-bs-target="#top100RoutesModal"><span class="top-100 mr-2 shrink-0"></span> Top 100 - {{ areaName }}</button>
								</li>
							{% endif %}
							<li>
								<button type="button" class="dropdown-item flex w-full items-center px-4 py-2 text-left text-sm text-gray-900 hover:bg-gray-100 dark:text-gray-100 dark:hover:bg-gray-800" data-bs-dismiss="dropdown" onclick="document.getElementById('modalWeather').showModal()"><span class="weather mr-2 shrink-0"></span> Wetter</button>
							</li>
							<li>
								<button type="button" class="dropdown-item flex w-full items-center px-4 py-2 text-left text-sm text-gray-900 hover:bg-gray-100 dark:text-gray-100 dark:hover:bg-gray-800" onclick="document.getElementById('modalAreaMap').showModal()"><span class="map mr-2 shrink-0"></span>Übersichtskarte {{ areaName }}</button>
							</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
