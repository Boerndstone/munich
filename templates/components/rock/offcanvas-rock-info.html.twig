{% if rocks is not empty %}
	{% set rock = rocks|first %}
	<dialog
		id="offcanvasRight"
		class="rock-info-dialog z-[1045] overflow-hidden bg-white text-gray-900 shadow-xl dark:bg-gray-900 dark:text-gray-100"
		aria-labelledby="offcanvasRightLabel"
		aria-modal="true"
		onclick="if (event.target === this) this.close()"
	>
		<div class="flex h-full min-h-0 flex-col" onclick="event.stopPropagation()">
			<div class="flex shrink-0 items-center justify-between border-b border-gray-200 px-3 py-2 dark:border-gray-700">
				<h2 class="text-base font-bold text-gray-900 dark:text-gray-100" id="offcanvasRightLabel">{{ rock.rockName }}</h2>
				<button type="button" class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md text-gray-500 hover:bg-gray-100 hover:text-gray-800 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200" onclick="this.closest('dialog').close()" aria-label="Schließen">
					<span class="sr-only">Schließen</span>
					<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
					</svg>
				</button>
			</div>
			<div class="min-h-0 flex-1 overflow-y-auto">
				<details class="rock-drawer-details border-b border-gray-200 dark:border-gray-700" open>
					<summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-3 text-sm font-bold marker:hidden [&::-webkit-details-marker]:hidden">
						<span class="rock-general-info me-2 text-gray-900 dark:text-gray-100" aria-hidden="true"></span>
						{{ "general.information"|trans }}
					</summary>
					<div class="border-t border-gray-100 px-0 pb-3 pt-0 text-sm dark:border-gray-800">
						<table class="w-full border-collapse text-sm font-medium">
							{% if rock.amountRoutes is defined and rock.amountRoutes > 0 %}
								<tr>
									<td colspan="2" class="border-0 pt-2">
										{{ include('components/grade-distribution-chart.html.twig', {
											grade_chart_source: rock,
											route_count: rock.amountRoutes,
											aria_label_prefix: rock.rockName ~ '. ',
											wrapper_class: 'max-w-full justify-start',
											include_projects_column: true,
											project_count: rock.amountProjects|default(0)
										}) }}
									</td>
								</tr>
							{% endif %}
							<tr>
								<td class="py-1 pe-2 align-top text-gray-600 dark:text-gray-400">{{ "height"|trans }}:</td>
								<td class="py-1">{{ rock.rockHeight }} m</td>
							</tr>
							<tr>
								<td class="py-1 pe-2 align-top text-gray-600 dark:text-gray-400">{{ "orientation"|trans }}:</td>
								<td class="py-1">{{ rock.rockOrientation }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2 align-top text-gray-600 dark:text-gray-400">{{ "sunny"|trans }}:</td>
								<td class="py-1">
									{% if rock.rockSunny is same as(true) %}
										{{ "sunny.property.sunny"|trans }}
									{% elseif rock.rockSunny is same as(false) %}
										{{ "sunny.property.sun"|trans }}
									{% else %}
										-
									{% endif %}
								</td>
							</tr>
							<tr>
								<td class="py-1 pe-2 align-top text-gray-600 dark:text-gray-400">{{ "child.friendly"|trans }}:</td>
								<td class="py-1">
									{% if rock.rockChild == 1 %}
										{{ "child.friendly.good"|trans }}
									{% else %}
										{{ "child.friendly.bad"|trans }}
									{% endif %}
								</td>
							</tr>
							<tr>
								<td class="py-1 pe-2 align-top text-gray-600 dark:text-gray-400">{{ "rain.proof"|trans }}:</td>
								<td class="py-1">
									{% if rock.rockRain is same as(true) %}
										{{ "rain.proof.good"|trans }}
									{% elseif rock.rockRain is same as(false) %}
										{{ "rain.proof.not"|trans }}
									{% else %}
										&mdash;
									{% endif %}
								</td>
							</tr>
							<tr>
								<td class="py-1 pe-2 align-top text-gray-600 dark:text-gray-400">{{ "gps"|trans }}:</td>
								<td class="py-1">{{ rock.rockLat }}, {{ rock.rockLng }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2 align-top text-gray-600 dark:text-gray-400">{{ "show.on.map"|trans }}:</td>
								<td class="py-1">
									<a href="https://www.google.com/maps?q={{ rock.rockLat }},{{ rock.rockLng }}" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted" aria-label="Open location in Google Maps (opens in new window)"><span class="inline-block -rotate-45">→</span> Google Maps</a>,<br />
									<a href="https://www.openstreetmap.org/?mlat={{ rock.rockLat }}&mlon={{ rock.rockLng }}&zoom=15" target="_blank" rel="noopener noreferrer" class="underline decoration-dotted" aria-label="Open location in OpenStreetMap (opens in new window)"><span class="inline-block -rotate-45">→</span> OpenStreetMap</a>
								</td>
							</tr>
							<tr>
								<td class="py-1 pe-2 align-top text-gray-600 dark:text-gray-400">{{ "season"|trans }}:</td>
								<td class="py-1">{{ rock.rockSeason }}</td>
							</tr>
							{% if rock.rockZone %}
								<tr>
									<td class="py-1 pe-2 align-top text-gray-600 dark:text-gray-400">{{ "zone"|trans }}:</td>
									<td class="py-1">{{ rock.rockZone }}</td>
								</tr>
							{% endif %}
						</table>
					</div>
				</details>

				{% set hasDescription = (description is defined and description is not null and description|striptags|trim != '') or (rock.rockDescription is defined and rock.rockDescription is not null and rock.rockDescription|striptags|trim != '') %}
				{% if hasDescription %}
					<details class="rock-drawer-details border-b border-gray-200 dark:border-gray-700">
						<summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-3 text-sm font-bold marker:hidden [&::-webkit-details-marker]:hidden">
							<span class="rock-general-description me-2 text-gray-900 dark:text-gray-100" aria-hidden="true"></span>
							{{ 'description'|trans }}
						</summary>
						<div class="border-t border-gray-100 px-3 pb-3 pt-2 text-sm dark:border-gray-800">
							{% if description is defined and description is not null and description|striptags|trim != '' %}
								{{ description|raw }}
							{% else %}
								{{ rock.rockDescription|raw }}
							{% endif %}
						</div>
					</details>
				{% endif %}

				{% set hasAccess = (access is defined and access is not null and access|striptags|trim != '') or (rock.rockAccess is defined and rock.rockAccess is not null and rock.rockAccess|striptags|trim != '') %}
				{% if hasAccess %}
					<details class="rock-drawer-details border-b border-gray-200 dark:border-gray-700">
						<summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-3 text-sm font-bold marker:hidden [&::-webkit-details-marker]:hidden">
							<span class="rock-general-access me-2 text-gray-900 dark:text-gray-100" aria-hidden="true"></span>
							{{ 'arrival.and.access'|trans }}
						</summary>
						<div class="border-t border-gray-100 px-3 pb-3 pt-2 text-sm dark:border-gray-800">
							{% if access is defined and access is not null and access|striptags|trim != '' %}
								{{ access|raw }}
							{% else %}
								{{ rock.rockAccess|raw }}
							{% endif %}
						</div>
					</details>
				{% endif %}

				<details id="rockMapDetails" class="rock-drawer-details border-b border-gray-200 dark:border-gray-700">
					<summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-3 text-sm font-bold marker:hidden [&::-webkit-details-marker]:hidden">
						<span class="rock-general-map me-2 text-gray-900 dark:text-gray-100" aria-hidden="true"></span>
						{{ 'map'|trans }}
					</summary>
					<div class="border-t border-gray-100 p-0 dark:border-gray-800">
						<div id="rockMap" class="z-10 mb-3 w-full" style="aspect-ratio: 16/16;">
							{{ include('components/map/rock-map.html.twig') }}
						</div>
					</div>
				</details>

				{% set hasNature = (nature is defined and nature is not null and nature|striptags|trim != '') or (rock.rockNature is defined and rock.rockNature is not null and rock.rockNature|striptags|trim != '') %}
				{% if hasNature %}
					<details class="rock-drawer-details border-b border-gray-200 dark:border-gray-700">
						<summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-3 text-sm font-bold marker:hidden [&::-webkit-details-marker]:hidden">
							<span class="rock-general-alert me-2 text-gray-900 dark:text-gray-100" aria-hidden="true"></span>
							{{ "climbing.regulations"|trans }}
						</summary>
						<div class="border-t border-gray-100 px-3 pb-3 pt-2 text-sm dark:border-gray-800">
							{% if nature is defined and nature is not null and nature|striptags|trim != '' %}
								{{ nature|raw }}
							{% else %}
								{{ rock.rockNature|raw }}
							{% endif %}
						</div>
					</details>
				{% endif %}

				{% if flowers is defined and flowers is not null %}
					<details class="rock-drawer-details border-b border-gray-200 dark:border-gray-700">
						<summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-3 text-sm font-bold marker:hidden [&::-webkit-details-marker]:hidden">
							<span class="rock-general-flowers me-2 text-gray-900 dark:text-gray-100" aria-hidden="true"></span>
							{{ "plants"|trans }}
						</summary>
						<div class="border-t border-gray-100 px-3 pb-3 pt-2 text-sm dark:border-gray-800">
							{{ flowers|raw }}
						</div>
					</details>
				{% endif %}

				{% if jsonData %}
					<details class="rock-drawer-details border-b border-gray-200 dark:border-gray-700">
						<summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-3 text-sm font-bold marker:hidden [&::-webkit-details-marker]:hidden">
							<span class="rock-general-images me-2 text-gray-900 dark:text-gray-100" aria-hidden="true"></span>
							{{ "images"|trans }}
						</summary>
						<div class="border-t border-gray-100 px-2 pb-3 pt-2 dark:border-gray-800" data-controller="off-canvas-gallery">
							<div class="mx-0 grid grid-cols-3 gap-1 md:grid-cols-4">
								{% for data in jsonData %}
									<div class="mb-1">
										<a class="lg-item block" data-target="lg-item" data-src="{{ data.src }}">
											<img src="{{ data.thumb }}" class="mb-1 w-full shadow-md" alt="{{ data.subHtml }}">
										</a>
									</div>
								{% endfor %}
							</div>
						</div>
					</details>
				{% endif %}

				<details class="rock-drawer-details border-b border-gray-200 dark:border-gray-700">
					<summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-3 text-sm font-bold marker:hidden [&::-webkit-details-marker]:hidden">
						<span class="rock-general-signs me-2 text-gray-900 dark:text-gray-100" aria-hidden="true"></span>
						{{ "explanation.symbols"|trans }}
					</summary>
					<div class="border-t border-gray-100 px-3 pb-3 pt-2 dark:border-gray-800" data-controller="off-canvas-gallery">
						<table class="w-full border-collapse text-sm font-medium">
							<tr>
								<td class="py-1 pe-2"><div class="star inline-block" aria-hidden="true"></div></td>
								<td class="py-1">{{ "nice.route"|trans }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2">
									<div class="flex gap-0">
										<div class="star inline-block" aria-hidden="true"></div>
										<div class="star inline-block" aria-hidden="true"></div>
									</div>
								</td>
								<td class="py-1">{{ "very.nice.route"|trans }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2">
									<div class="flex gap-0">
										<div class="star" aria-hidden="true"></div>
										<div class="star" aria-hidden="true"></div>
										<div class="star" aria-hidden="true"></div>
									</div>
								</td>
								<td class="py-1">{{ "dream.route"|trans }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2"><div class="trash" aria-hidden="true"></div></td>
								<td class="py-1">{{ "shit.route"|trans }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2"><div class="exclamation inline-block" aria-hidden="true"></div></td>
								<td class="py-1">{{ "bad.routeprotection"|trans }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2"><div class="skull inline-block" aria-hidden="true"></div></td>
								<td class="py-1">{{ "dangerous.routeprotection"|trans }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2"><div class="loose-rock inline-block" aria-hidden="true"></div></td>
								<td class="py-1">{{ "rock.quality"|trans }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2"><div class="multi-pitch inline-block" aria-hidden="true"></div></td>
								<td class="py-1">{{ "multi.pitch"|trans }}</td>
							</tr>
							<tr>
								<td class="py-1 pe-2"><div class="crack-climbing inline-block" aria-hidden="true"></div></td>
								<td class="py-1">{{ "crack.climbing"|trans }}</td>
							</tr>
						</table>
					</div>
				</details>

				<details class="rock-drawer-details border-b border-gray-200 dark:border-gray-700">
					<summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-3 text-sm font-bold marker:hidden [&::-webkit-details-marker]:hidden">
						<span class="rock-general-improvement me-2 text-gray-900 dark:text-gray-100" aria-hidden="true"></span>
						{{ "rock_improvement.title"|trans }}
					</summary>
					<div class="border-t border-gray-100 px-3 pb-4 pt-2 text-sm dark:border-gray-800">
						{% if improvementForm is defined and improvementForm is not null %}
							<p class="mb-3 text-sm text-gray-600 dark:text-gray-400">{{ "rock_improvement.intro"|trans({ "%rock_name%": rock.rockName }) }}</p>
							{{ form_start(improvementForm, { 'action': path('show_rock', { areaSlug: areaSlug, slug: slug }), 'attr': { 'class': 'space-y-2 text-sm' } }) }}
							{{ form_row(improvementForm.rockName) }}
							{{ form_row(improvementForm.name) }}
							{{ form_row(improvementForm.routeName) }}
							{{ form_row(improvementForm.grade) }}
							{{ form_row(improvementForm.firstAscent) }}
							{{ form_row(improvementForm.comment) }}
							<button type="submit" class="mt-2 inline-flex rounded-md bg-green-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-green-700 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-green-500">{{ "rock_improvement.submit"|trans }}</button>
							{{ form_end(improvementForm) }}
						{% endif %}
					</div>
				</details>
			</div>
		</div>
	</dialog>
{% endif %}
