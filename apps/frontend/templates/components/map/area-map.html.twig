{% set marker = [] %}
{% for rock in rocks %}
	{% set rockLink = rock_path(rock.areaSlug, rock.rockSlug) %}
	{% set rockCardArea = {
		routes: rock.amountRoutes|default(0),
		amountEasy: rock.amountEasy|default(0),
		amountMiddle: rock.amountMiddle|default(0),
		amountHard: rock.amountHard|default(0),
		amountProjects: rock.amountProjects|default(0),
		grade_chart_3: rock.grade_chart_3|default(0),
		grade_chart_4: rock.grade_chart_4|default(0),
		grade_chart_5: rock.grade_chart_5|default(0),
		grade_chart_6: rock.grade_chart_6|default(0),
		grade_chart_7: rock.grade_chart_7|default(0),
		grade_chart_8: rock.grade_chart_8|default(0),
		grade_chart_9: rock.grade_chart_9|default(0),
		grade_chart_10: rock.grade_chart_10|default(0),
		grade_chart_11: rock.grade_chart_11|default(0)
	} %}
	{% set popupBody = include('components/area/area-card-body.html.twig', {
		area: rockCardArea,
		ulClass: 'mt-2',
		showTravelTime: false,
		showRocksCount: false,
		aria_label_prefix: 'Klettergebiet ' ~ areaName ~ ', Fels ' ~ rock.rockName ~ '. ',
		compact_chart: true,
		fill_chart_panel: true,
		hide_y_axis: true
	}) %}
	{% set rockName = include('components/map/rock-map-popup.html.twig', {
		rock: rock,
		areaName: areaName,
		rockLink: rockLink,
		popupBody: popupBody
	})|trim %}

	{% set rockImage = '' %}
	{% set childFriendly = rock.rockChild is defined and rock.rockChild == 1 %}
	{% set sunny = rock.rockSunny is defined and rock.rockSunny %}
	{% set rain = rock.rockRain is defined and rock.rockRain %}
	{% set train = rock.rockTrain is defined and rock.rockTrain == 1 %}
	{% set bike = rock.rockBike is defined and rock.rockBike == 1 %}
	{% set marker = marker|merge([[ rock.rockLat, rock.rockLng, rockName, rockImage, childFriendly, sunny, rain, train, bike ]]) %}
{% endfor %}
{% set intialZoom = [] %}
{% set intialZoom = intialZoom|merge([areaLat, areaLng, areaZoom]) %}
{% set railwayStation = areaRailwayStation %}

<div 
	class="main-map-container flex min-h-0 flex-1 flex-col" 
	data-controller="map" 
	data-map-markers-area="{{ marker|json_encode|e('html_attr') }}" 
	data-map-zoom="{{ intialZoom|json_encode|e('html_attr') }}" 
	data-map-railway-stations="{{ railwayStation|json_encode|e('html_attr') }}"
>
	<div class="area-map-filters shrink-0 px-3 py-2">
		<div class="main-map-filters-scroll">
			<ul class="main-map-filters-list">
				<li class="main-map-filters-label">Filter:</li>
				<li><button type="button" class="py-1 main-map-filter-tab active" data-map-target="layerBtn" data-layer="rocks" aria-pressed="true">Felsen</button></li>
				<li><button type="button" class="py-1 main-map-filter-tab active" data-map-target="layerBtn" data-layer="railway" aria-pressed="true">Bahnhöfe</button></li>
				<li><button type="button" class="py-1 main-map-filter-tab active" data-map-target="layerBtn" data-layer="camping" aria-pressed="true">Übernachtung</button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-map-target="attrFilterBtn" data-attr="childFriendly" aria-pressed="false" title="Kinderfreundlich" aria-label="Kinderfreundlich"><span class="child-friendly shrink-0" aria-hidden="true"></span></button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-map-target="attrFilterBtn" data-attr="sunny" aria-pressed="false" title="Sonnig" aria-label="Sonnig"><span class="sun shrink-0" aria-hidden="true"></span></button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-map-target="attrFilterBtn" data-attr="rain" aria-pressed="false" title="Regenschutz" aria-label="Regenschutz"><span class="umbrella shrink-0" aria-hidden="true"></span></button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-map-target="attrFilterBtn" data-attr="train" aria-pressed="false" title="{{ 'train.reachable'|trans }}" aria-label="{{ 'train.reachable'|trans }}"><span class="train shrink-0" aria-hidden="true"></span></button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-map-target="attrFilterBtn" data-attr="bike" aria-pressed="false" title="{{ 'bike.reachable'|trans }}" aria-label="{{ 'bike.reachable'|trans }}"><span class="bike shrink-0" aria-hidden="true"></span></button></li>
			</ul>
		</div>
	</div>
	<div class="min-h-0 flex-1" data-map-target="map"></div>
</div>
