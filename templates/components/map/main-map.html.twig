<div class="main-map-container flex min-h-0 flex-1 flex-col" data-controller="index-areas-map-filters">
	<div class="main-map-filters shrink-0 px-3 py-2" role="group" aria-labelledby="main-map-filter-legend">
		<div class="main-map-filters-scroll">
			<ul class="main-map-filters-list">
				<li id="main-map-filter-legend" class="main-map-filters-label">Entfernung von München:</li>
				<li><button type="button" class="main-map-filter-tab active" data-index-areas-map-filters-target="filterBtn" data-range="all" aria-pressed="true" data-action="click->index-areas-map-filters#applyFilter">Alle</button></li>
				<li><button type="button" class="main-map-filter-tab" data-index-areas-map-filters-target="filterBtn" data-range="0-60" aria-pressed="false" data-action="click->index-areas-map-filters#applyFilter">&lt; 1 h</button></li>
				<li><button type="button" class="main-map-filter-tab" data-index-areas-map-filters-target="filterBtn" data-range="60-90" aria-pressed="false" data-action="click->index-areas-map-filters#applyFilter">1 – 1,5 h</button></li>
				<li><button type="button" class="main-map-filter-tab" data-index-areas-map-filters-target="filterBtn" data-range="120-9999" aria-pressed="false" data-action="click->index-areas-map-filters#applyFilter">> 2 h</button></li>
			</ul>
		</div>
	</div>
	<div class="flex min-h-0 flex-1 flex-col" role="region" aria-label="{{ 'index.map_region'|trans({}, 'messages') }}">
		{{ ux_map(indexMap, {
			class: 'z-10 flex h-full w-full min-h-[min(360px,52vh)] flex-1 flex-col',
			style: 'min-height:min(360px,52vh)',
		}) }}
	</div>
</div>
