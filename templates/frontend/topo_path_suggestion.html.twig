{% extends 'base.html.twig' %}

{% block title %}{{ 'topo_path_suggestion.title'|trans }} | Munichclimbs{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	{% include 'topo_path_editor/_styles.html.twig' %}
{% endblock %}

{% block body %}
	{{ include('components/layout/navigation.html.twig') }}
	<main id="main-content">
		<div class="mx-auto w-full max-w-[1024px] px-2 py-6 sm:px-4">
			<section>
				<h1 class="mb-3 text-2xl font-medium text-gray-900 dark:text-gray-100">{{ 'topo_path_suggestion.title'|trans }}</h1>
				<p class="mb-6 max-w-2xl text-sm leading-relaxed text-gray-600 dark:text-gray-400">
					{{ 'topo_path_suggestion.intro'|trans }}
				</p>
			</section>

			{% if sent %}
				<div class="relative mb-6 max-w-2xl rounded-lg border border-emerald-200 bg-emerald-50 p-4 pe-10 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950/40 dark:text-emerald-100" role="status">
					{{ 'topo_path_suggestion.success'|trans }}
					<button type="button" class="absolute end-2 top-2 inline-flex h-8 w-8 items-center justify-center rounded-md text-emerald-800 hover:bg-emerald-100 focus-visible:outline focus-visible:ring-2 focus-visible:ring-emerald-500 dark:text-emerald-200 dark:hover:bg-emerald-900/60" onclick="this.closest('[role=status]').remove()" aria-label="{{ 'close'|trans }}">
						<span class="sr-only">{{ 'close'|trans }}</span>
						<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
						</svg>
					</button>
				</div>
			{% endif %}

			<section class="mb-8 max-w-2xl rounded-lg border border-gray-200 bg-gray-50/80 p-4 dark:border-gray-700 dark:bg-gray-900/40">
				<h2 class="mb-2 text-base font-medium text-gray-900 dark:text-gray-100">{{ 'topo_path_suggestion.filter_heading'|trans }}</h2>
				<p class="mb-4 text-sm text-gray-600 dark:text-gray-400">{{ 'topo_path_suggestion.filter_help'|trans }}</p>
				<form method="get" action="{{ path(app.request.locale == 'en' ? 'frontend_topo_path_suggestion_en' : 'frontend_topo_path_suggestion') }}" class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-end">
					<div class="min-w-[12rem] flex-1">
						<label for="tph-suggestion-rock" class="mb-1 block text-sm font-medium text-gray-800 dark:text-gray-200">{{ 'topo_path_suggestion.rock_label'|trans }}</label>
						<select id="tph-suggestion-rock" name="rock" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 dark:border-gray-600 dark:bg-gray-900 dark:text-gray-100">
							<option value="">{{ 'upload_photo.placeholder.rock'|trans }}</option>
							{% for rock in rocks %}
								<option value="{{ rock.id }}"{% if selectedRockId is not null and rock.id == selectedRockId %} selected{% endif %}>{{ rock.name }}</option>
							{% endfor %}
						</select>
					</div>
					<div class="w-full sm:w-28">
						<label for="tph-suggestion-topoNr" class="mb-1 block text-sm font-medium text-gray-800 dark:text-gray-200">{{ 'topo_path_suggestion.topo_nr_label'|trans }}</label>
						<input type="number" min="1" step="1" id="tph-suggestion-topoNr" name="topoNr" value="{{ selectedTopoNr ?? '' }}" class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 dark:border-gray-600 dark:bg-gray-900 dark:text-gray-100" placeholder="1">
					</div>
					<button type="submit" class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-800 shadow-sm hover:bg-gray-50 focus-visible:outline focus-visible:ring-2 focus-visible:ring-sky-500 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100 dark:hover:bg-gray-700">
						{{ 'topo_path_suggestion.filter_submit'|trans }}
					</button>
				</form>
			</section>

			<section class="mb-8 max-w-2xl">
				<h2 class="mb-3 text-base font-medium text-gray-900 dark:text-gray-100">{{ 'topo_path_suggestion.contact_heading'|trans }}</h2>
				<div class="flex flex-col gap-3">
					<div>
						<label for="tph-suggestion-name" class="mb-1 block text-sm font-medium text-gray-800 dark:text-gray-200">{{ 'topo_path_suggestion.name'|trans }}</label>
						<input type="text" id="tph-suggestion-name" name="suggestion_name" autocomplete="name" class="w-full max-w-md rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 dark:border-gray-600 dark:bg-gray-900 dark:text-gray-100">
					</div>
					<div>
						<label for="tph-suggestion-email" class="mb-1 block text-sm font-medium text-gray-800 dark:text-gray-200">{{ 'topo_path_suggestion.email'|trans }}</label>
						<input type="email" id="tph-suggestion-email" name="suggestion_email" autocomplete="email" class="w-full max-w-md rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 dark:border-gray-600 dark:bg-gray-900 dark:text-gray-100">
					</div>
					<div>
						<label for="tph-suggestion-comment" class="mb-1 block text-sm font-medium text-gray-800 dark:text-gray-200">{{ 'topo_path_suggestion.comment'|trans }}</label>
						<textarea id="tph-suggestion-comment" rows="3" class="w-full max-w-md rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-1 focus:ring-sky-500 dark:border-gray-600 dark:bg-gray-900 dark:text-gray-100"></textarea>
					</div>
					<div>
						<label for="tph-suggestion-refImage" class="mb-1 block text-sm font-medium text-gray-800 dark:text-gray-200">{{ 'topo_path_suggestion.ref_image'|trans }}</label>
						<input type="file" id="tph-suggestion-refImage" accept="image/*" class="block w-full max-w-md text-sm text-gray-600 file:me-3 file:rounded-md file:border-0 file:bg-sky-600 file:px-3 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-sky-700 dark:text-gray-300">
					</div>
					<div class="absolute -start-[9999px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
						<label for="tph-suggestion-website">Website</label>
						<input type="text" id="tph-suggestion-website" name="website" tabindex="-1" autocomplete="off">
					</div>
				</div>
			</section>

			<div class="mb-6">
				{% include 'topo_path_editor/_body_root.html.twig' with { frontend_class: 'topo-path-helper-root--frontend' } %}
			</div>

			<div class="mb-10 flex flex-wrap items-center gap-3">
				<button type="button" id="tph-saveToTopo" class="inline-flex items-center justify-center rounded-md border border-emerald-700 bg-emerald-600 px-4 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-emerald-700 focus-visible:outline focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 dark:border-emerald-600 dark:bg-emerald-600 dark:hover:bg-emerald-500 dark:focus-visible:ring-offset-gray-900" data-csrf-token="{{ csrf_token(constant('App\\Controller\\TopoPathSuggestionController::CSRF_INTENT_SEND'))|e('html_attr') }}">
					{{ 'topo_path_suggestion.submit'|trans }}
				</button>
				<a href="{{ path(app.request.locale == 'en' ? 'index_en' : 'index') }}" class="text-sm font-medium text-sky-700 hover:text-sky-900 dark:text-sky-400 dark:hover:text-sky-300">{{ 'topo_path_suggestion.back_home'|trans }}</a>
			</div>

			<div id="tph-topo-edit" style="display:none" data-json="{{ topoEditJsonBase64|e('html_attr') }}"></div>
			<script>
			window.TOPO_EDIT = (function(){
				var el = document.getElementById('tph-topo-edit');
				var b64 = el && el.getAttribute('data-json');
				if (!b64) return null;
				try { return JSON.parse(atob(b64)); } catch (e) { return null; }
			})();
			</script>
			{{ encore_entry_script_tags('topo_editor') }}
		</div>
	</main>
{% endblock %}
