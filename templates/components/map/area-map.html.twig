<div class="main-map-container flex min-h-0 flex-1 flex-col" data-controller="area-overview-map-filters">
	<div class="area-map-filters shrink-0 px-3 py-2">
		<div class="main-map-filters-scroll">
			<ul class="main-map-filters-list">
				<li class="main-map-filters-label">Filter:</li>
				<li><button type="button" class="py-1 main-map-filter-tab active" data-area-overview-map-filters-target="layerBtn" data-layer="rocks" aria-pressed="true" data-action="click->area-overview-map-filters#toggleLayer">Felsen</button></li>
				<li><button type="button" class="py-1 main-map-filter-tab active" data-area-overview-map-filters-target="layerBtn" data-layer="railway" aria-pressed="true" data-action="click->area-overview-map-filters#toggleLayer">Bahnhöfe</button></li>
				<li><button type="button" class="py-1 main-map-filter-tab active" data-area-overview-map-filters-target="layerBtn" data-layer="camping" aria-pressed="true" data-action="click->area-overview-map-filters#toggleLayer">Übernachtung</button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-area-overview-map-filters-target="attrFilterBtn" data-attr="childFriendly" aria-pressed="false" title="Kinderfreundlich" aria-label="Kinderfreundlich" data-action="click->area-overview-map-filters#toggleAttrFilter"><span class="child-friendly shrink-0" aria-hidden="true"></span></button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-area-overview-map-filters-target="attrFilterBtn" data-attr="sunny" aria-pressed="false" title="Sonnig" aria-label="Sonnig" data-action="click->area-overview-map-filters#toggleAttrFilter"><span class="sun shrink-0" aria-hidden="true"></span></button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-area-overview-map-filters-target="attrFilterBtn" data-attr="rain" aria-pressed="false" title="Regenschutz" aria-label="Regenschutz" data-action="click->area-overview-map-filters#toggleAttrFilter"><span class="umbrella shrink-0" aria-hidden="true"></span></button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-area-overview-map-filters-target="attrFilterBtn" data-attr="train" aria-pressed="false" title="{{ 'train.reachable'|trans }}" aria-label="{{ 'train.reachable'|trans }}" data-action="click->area-overview-map-filters#toggleAttrFilter"><span class="train shrink-0" aria-hidden="true"></span></button></li>
				<li><button type="button" class="flex items-center justify-center py-1 main-map-filter-tab main-map-filter-tab-icon" data-area-overview-map-filters-target="attrFilterBtn" data-attr="bike" aria-pressed="false" title="{{ 'bike.reachable'|trans }}" aria-label="{{ 'bike.reachable'|trans }}" data-action="click->area-overview-map-filters#toggleAttrFilter"><span class="bike shrink-0" aria-hidden="true"></span></button></li>
			</ul>
		</div>
	</div>
	<div class="flex min-h-0 flex-1 flex-col">
		{{ ux_map(areaOverviewMap, {
			class: 'z-10 flex h-full w-full min-h-0 flex-1 flex-col',
			style: 'min-height:min(280px, 45vh)',
		}) }}
	</div>
</div>
