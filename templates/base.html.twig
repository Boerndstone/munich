<!DOCTYPE html>
<html lang="{{ app.locale }}">
	<head>
		<meta charset="UTF-8">
		<meta http-equiv="X-UA-Compatible" content="IE=edge">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		
		{# Preconnect to external resources for faster loading #}
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preconnect" href="https://www.munichclimbs.de">
		<link rel="dns-prefetch" href="https://unpkg.com">
		
		{% block meta_tags %}{% endblock %}
		{% block structured_data %}{% endblock %}
		<title>
			{% block title %}Munichclimbs
			{% endblock %}
		</title>
		{% block stylesheets %}
			{{ encore_entry_link_tags('app') }}
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Spartan:wght@400;500;600;700&display=swap">
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Chelsea+Market&display=swap">
		{% endblock %}
		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}
		{% block page_javascripts %}{% endblock %}
		<link href="{{ asset('build/images/favicon/favicon.png') }}" rel="icon" type="image/png">
		<link href="{{ asset('build/images/favicon/favicon.ico') }}" rel="shortcut icon" type="image/x-icon">
		<link href="{{ asset('build/images/favicon/apple-touch-icon.png') }}" rel="apple-touch-icon" sizes="180x180">
		<link href="{{ asset('build/images/favicon/apple-touch-startup-image.png') }}" rel="apple-touch-startup-image">
		{# Leaflet - CSS and JS loaded in head (required because map init scripts run inline in body) #}
		{% block leaflet %}{% endblock %}
	</head>
	<body id="body" {% block body_attributes %} {% endblock %} class="{% block bodyclass %}{% endblock %}" data-controller="search-modal" data-search-modal-search-url-value="{{ path('search_autocomplete') }}">
		<div data-controller="scroll-progress" class="bg-theme fixed start-0 end-0 top-0" style="height: 3px; z-index: 10000;"></div>

		<a href="#main-content" class="sr-only start-4 top-4 z-[1080] rounded-md bg-sky-700 px-3 py-2 text-sm font-medium text-white shadow focus:fixed focus:not-sr-only focus:outline-hidden focus-visible:ring-2 focus-visible:ring-sky-300">{{ 'skip_to_content'|trans({}, 'messages') }}</a>

		<a id="main-content" tabindex="-1"></a>
		{% block body %}{% endblock %}

		{% include 'components/layout/footer.html.twig' with {'areas': getAreas()} %}

		{{ include('components/layout/search-modal.html.twig') }}

		<div {{ stimulus_controller('cookie-consent') }}></div>

		<a href="#body" data-controller="scrolltop" data-action="scroll@window->scrolltop#scrollFunction" data-scrolltop-target="top" class="btn-to-top hidden fixed bottom-5 end-5 z-[1070] h-10 w-10 items-center justify-center rounded-full border border-gray-400 bg-white text-gray-800 shadow-md hover:bg-gray-50 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-gray-400 dark:border-gray-600 dark:bg-gray-900 dark:text-gray-100 dark:hover:bg-gray-800" aria-label="{{ 'scroll_to_top'|trans({}, 'messages') }}">
			<div class="chevron-up" aria-hidden="true"></div>
		</a>
	</body>
</html>
