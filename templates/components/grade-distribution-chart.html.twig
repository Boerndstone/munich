{# Bar chart of route counts per grade (3–11). Stimulus: rock-grade-chart (Chart.js, app bundle).
   Pass either:
   - grade_chart_counts: array of 9 integers [grad3 … grad11], and route_count, OR
   - grade_chart_source: object with grade_chart_3 … grade_chart_11, plus route_count (or .routes).
   Optional: include_projects_column + project_count — 10th bar labeled "Proj." on the chart.
   Optional: aria_label_prefix, wrapper_class.
   Optional: chart_summary_include_rocks + chart_rocks_count — e.g. index cards show "Touren · Felsen" above the chart.
   Optional: hide_chart_summary_line — omit the route total line above the canvas (e.g. area rocks listing).
   Optional: compact — shorter chart (map rock popups).
   Optional: fill_panel — with compact + main-map grid bottom row: chart grows to fill panel (no dead zone).
   Optional: hide_y_axis — main-map rock popup only: hide amount (Y) scale; counts stay on bars + aria.
#}
{% if grade_chart_counts is not defined %}
	{% set grade_chart_counts = [
		attribute(grade_chart_source, 'grade_chart_3')|default(0),
		attribute(grade_chart_source, 'grade_chart_4')|default(0),
		attribute(grade_chart_source, 'grade_chart_5')|default(0),
		attribute(grade_chart_source, 'grade_chart_6')|default(0),
		attribute(grade_chart_source, 'grade_chart_7')|default(0),
		attribute(grade_chart_source, 'grade_chart_8')|default(0),
		attribute(grade_chart_source, 'grade_chart_9')|default(0),
		attribute(grade_chart_source, 'grade_chart_10')|default(0),
		attribute(grade_chart_source, 'grade_chart_11')|default(0)
	] %}
{% endif %}
{% if include_projects_column|default(false) %}
	{% set grade_chart_counts = grade_chart_counts|merge([project_count|default(0)]) %}
{% endif %}
{% set route_total = route_count|default(0) %}
{% if route_total < 1 and grade_chart_source is defined %}
	{% set route_total = grade_chart_source.routes|default(0) %}
{% endif %}
{% if route_total > 0 %}
	{% set rocks_n = chart_rocks_count|default(0) %}
	{% if chart_summary_include_rocks|default(false) %}
		{% set chart_summary_visible = 'grade_chart.summary_routes_and_rocks'|trans({ '%routes%': route_total, '%rocks%': rocks_n }) %}
		{% set chart_aria_total_fragment = 'grade_chart.aria_summary_routes_and_rocks'|trans({ '%routes%': route_total, '%rocks%': rocks_n }) %}
	{% else %}
		{% set chart_summary_visible = 'grade_chart.total_routes'|trans({ '%count%': route_total }) %}
		{% set chart_aria_total_fragment = 'grade_chart.aria_total_prefix'|trans({ '%count%': route_total }) %}
	{% endif %}
	{% if hide_chart_summary_line|default(false) %}
		{% set chart_aria_total_fragment = '' %}
	{% endif %}
	{% set _compact = compact|default(false) %}
	{% set _fill = _compact and fill_panel|default(false) %}
	{% set _chartH = _fill ? '' : (_compact ? 'h-9' : 'h-28') %}
	{% set _chartMax = _fill ? '' : (_compact ? 'max-h-9' : 'max-h-28') %}
	{% set _sumMb = _compact ? 'mb-0' : 'mb-2' %}
	{% set _sumText = _compact ? 'text-[11px] leading-tight' : 'text-xs' %}
	<div class="not-prose flex min-w-0 flex-col {{ hide_chart_summary_line|default(false) ? 'gap-0' : (_compact ? 'gap-0' : 'gap-0.5') }} {{ _fill ? 'h-full min-h-0 flex-1' : '' }} {{ wrapper_class|default('') }}">
		{% if not hide_chart_summary_line|default(false) %}
			<p class="{{ _sumMb }} w-full text-left {{ _sumText }} font-medium tabular-nums text-black dark:text-white pointer-events-none" aria-hidden="true">
				{{ chart_summary_visible }}
			</p>
		{% endif %}
		{% if not _compact %}
			<div class="flex justify-between">
				<p class="mb-0 w-full text-left text-[10px] font-normal leading-tight text-gray-500 dark:text-gray-400 pointer-events-none flex items-center gap-1" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24"><path fill="currentColor" d="M4.08 11.92L12 4l7.92 7.92l-1.42 1.41l-5.5-5.5V22h-2V7.83l-5.5 5.5zM12 4h10V2H2v2z"/></svg><span>{{ 'grade_chart.legend_y'|trans }}</span>
				</p>
				<p class="mb-0 w-full text-right text-[10px] font-normal leading-tight text-gray-500 dark:text-gray-400 pointer-events-none flex items-center justify-end gap-1" aria-hidden="true">
					<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24"><path fill="currentColor" d="M12.08 4.08L20 12l-7.92 7.92l-1.41-1.42l5.5-5.5H2v-2h14.17l-5.5-5.5zM20 12v10h2V2h-2z"/></svg>
					<span>{{ 'grade_chart.legend_x'|trans }}</span>
				</p>
			</div>
		{% endif %}
		<div
			class="pointer-events-none flex w-full gap-1 {{ _fill ? 'min-h-0 flex-1 flex-col' : 'items-end' }}"
			data-controller="rock-grade-chart"
			data-rock-grade-chart-counts-value="{{ grade_chart_counts|json_encode|e('html_attr') }}"
			data-rock-grade-chart-aria-prefix-value="{{ aria_label_prefix|default('')|e('html_attr') }}"
			data-rock-grade-chart-aria-total-prefix-value="{{ chart_aria_total_fragment|e('html_attr') }}"
			{% if hide_y_axis|default(false) %}data-rock-grade-chart-hide-y-axis-value="true"{% endif %}
			role="img"
			aria-label="{{ aria_label_prefix|default('') }}{{ chart_aria_total_fragment }}Routen je Gradstufe."
		>
			<div class="relative min-w-0 flex-1 {{ _chartH }} {{ _fill ? 'min-h-0' : '' }}">
				<canvas class="{{ _chartMax }} {{ _fill ? 'min-h-0' : '' }} h-full w-full" aria-hidden="true"></canvas>
			</div>
		</div>
		
	</div>
{% endif %}
