<div class="mx-auto max-w-[1024px] px-2">
	{% for message in app.flashes('success') %}
		<div class="relative mt-3 rounded-md border border-green-600 bg-green-50 px-3 py-2 pe-10 text-sm text-green-900 dark:border-green-500 dark:bg-green-950/40 dark:text-green-100" role="alert" data-controller="auto-dismiss-alert" data-auto-dismiss-alert-dismiss-after-value="2">
			{{ message }}
			<button type="button" class="absolute end-2 top-1/2 inline-flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-md text-green-800 hover:bg-green-100 dark:text-green-200 dark:hover:bg-green-900/50" data-action="click->auto-dismiss-alert#dismiss" aria-label="Schließen">
				<span class="sr-only">Schließen</span>
				<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
				</svg>
			</button>
		</div>
	{% endfor %}
	{% for message in app.flashes('error') %}
		<div class="relative mt-3 rounded-md border border-red-600 bg-red-50 px-3 py-2 pe-10 text-sm text-red-900 dark:border-red-500 dark:bg-red-950/40 dark:text-red-100" role="alert" data-controller="auto-dismiss-alert" data-auto-dismiss-alert-dismiss-after-value="8">
			{{ message }}
			<button type="button" class="absolute end-2 top-1/2 inline-flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-md text-red-800 hover:bg-red-100 dark:text-red-200 dark:hover:bg-red-900/50" data-action="click->auto-dismiss-alert#dismiss" aria-label="Schließen">
				<span class="sr-only">Schließen</span>
				<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
				</svg>
			</button>
		</div>
	{% endfor %}
</div>
