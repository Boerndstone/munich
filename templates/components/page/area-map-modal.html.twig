{# Expects: areaName #}
<dialog
	id="modalAreaMap"
	class="map-fullscreen-dialog fixed inset-0 z-[1060] m-0 max-h-none max-w-none translate-x-0 translate-y-0 overflow-hidden border-0 bg-white p-0 text-gray-900 shadow-none"
	aria-labelledby="modalAreaMapLabel"
	aria-modal="true"
	onclick="if (event.target === this) this.close()"
>
	<div class="map-fullscreen-dialog__panel">
		<header class="flex shrink-0 items-center justify-between gap-3 border-b border-gray-200 px-4 py-2">
			<h2 id="modalAreaMapLabel" class="text-base font-semibold leading-tight text-gray-900">Übersichtskarte {{ areaName }}</h2>
			<button
				type="button"
				class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md text-gray-500 transition-colors hover:bg-gray-100 hover:text-gray-800 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-gray-400"
				onclick="this.closest('dialog').close()"
				aria-label="Schließen"
			>
				<span class="sr-only">Schließen</span>
				<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
				</svg>
			</button>
		</header>
		<div class="flex min-h-0 flex-1 flex-col overflow-hidden">
			<div id="areaMap" class="z-10 flex min-h-0 flex-1 flex-col">
				{{ include('components/map/area-map.html.twig', { areaOverviewMap: areaOverviewMap }) }}
			</div>
		</div>
	</div>
</dialog>
