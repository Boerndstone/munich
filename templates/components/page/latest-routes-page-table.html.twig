{# Full-page latest routes table. Expects: latestRoutes #}
	<div class="w-full overflow-x-auto">
		<table class="min-w-[720px] w-full text-left text-sm font-medium text-gray-900 dark:text-gray-100">
			<thead>
				<tr>
					<th scope="col" class="px-3 py-2">#</th>
					<th scope="col" class="px-3 py-2">Tour</th>
					<th scope="col" class="px-3 py-2">Schwierigkeit</th>
					<th scope="col" class="px-3 py-2">Erstbegeher</th>
					<th scope="col" class="px-3 py-2">Fels</th>
				</tr>
			</thead>
			<tbody class="divide-y divide-gray-200 dark:divide-gray-700">
				{% for latestRoute in latestRoutes %}
					<tr class="even:bg-white odd:bg-gray-100 hover:bg-gray-200 dark:even:bg-black dark:odd:bg-gray-800 dark:hover:bg-gray-700">
						<td class="px-3 py-2">{{ loop.index }}</td>
						<td class="px-3 py-2">
							<a href="{{ path('show_rock', { areaSlug: latestRoute.area.slug, slug: latestRoute.rock.slug }) }}" title="Tourenname: {{ latestRoute.name }}, Fels: {{ latestRoute.rock }}" class="text-sky-800 no-underline hover:underline dark:text-sky-400">{{ latestRoute.name }}
							</a>
							{% set routeRating = latestRoute.rating|default(0) %}
							{% if routeRating >= 1 and routeRating <= 3 %}
								<span class="visually-hidden">Bewertung: {{ routeRating }} von 3 Sternen.</span>
								{% for _i in 1..routeRating %}
									<i class="fas fa-star text-amber-600 dark:text-amber-400" aria-hidden="true"></i>
								{% endfor %}
							{% endif %}
							{% if latestRoute.protection == 2 %}
								<span class="visually-hidden">Hinweis: erschwerte Absicherung.</span>
								<i class="fa fa-exclamation-triangle text-red-700 dark:text-red-500" aria-hidden="true"></i>
							{% elseif latestRoute.protection == 3 %}
								<span class="visually-hidden">Hinweis: sehr erschwerte oder unzureichende Absicherung.</span>
								<i class="fa fa-ambulance text-red-700 dark:text-red-500" aria-hidden="true"></i>
							{% endif %}
						</td>
						<td class="px-3 py-2">{{ latestRoute.grade }}</td>
						<td class="px-3 py-2">{{ latestRoute.firstAscent }}
							{{ latestRoute.yearFirstAscent }}</td>
						<td class="px-3 py-2">{{ latestRoute.rock }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>
	</div>
