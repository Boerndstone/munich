{% extends 'base.html.twig' %}
{% form_theme form 'form/tailwind_form_layout.html.twig' %}

{% block title %}Foto hochladen - Munichclimbs{% endblock %}

{% block body %}
	{{ include('components/layout/navigation.html.twig') }}
	<main id="main-content">
		<div class="mx-auto w-full max-w-[1024px] px-2 py-6 sm:px-4">
			<section>
				<div class="mb-3 flex items-center justify-between py-3">
					<h1 class="mb-0 text-2xl font-medium text-gray-900 dark:text-gray-100">Foto hochladen</h1>
				</div>
			</section>
			<section class="max-w-2xl">
				<p class="mb-6 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
					Helfen Sie mit, die Seite zu verbessern! Wählen Sie einen Fels und optional eine Route, laden Sie ein Foto hoch.
					Ihr Foto wird von einem Administrator geprüft und nach Freigabe auf der Seite veröffentlicht.
				</p>

				{% for message in app.flashes('success') %}
					<div class="relative mb-4 rounded-lg border border-emerald-200 bg-emerald-50 p-4 pe-10 text-sm text-emerald-900 dark:border-emerald-900 dark:bg-emerald-950/40 dark:text-emerald-100" role="alert">
						{{ message }}
						<button type="button" class="absolute end-2 top-2 inline-flex h-8 w-8 items-center justify-center rounded-md text-emerald-800 hover:bg-emerald-100 focus-visible:outline focus-visible:ring-2 focus-visible:ring-emerald-500 dark:text-emerald-200 dark:hover:bg-emerald-900/60" onclick="this.closest('[role=alert]').remove()" aria-label="Schließen">
							<span class="sr-only">Schließen</span>
							<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
							</svg>
						</button>
					</div>
				{% endfor %}

				{% for message in app.flashes('error') %}
					<div class="relative mb-4 rounded-lg border border-red-200 bg-red-50 p-4 pe-10 text-sm text-red-900 dark:border-red-900 dark:bg-red-950/40 dark:text-red-100" role="alert">
						{{ message }}
						<button type="button" class="absolute end-2 top-2 inline-flex h-8 w-8 items-center justify-center rounded-md text-red-800 hover:bg-red-100 focus-visible:outline focus-visible:ring-2 focus-visible:ring-red-500 dark:text-red-200 dark:hover:bg-red-900/60" onclick="this.closest('[role=alert]').remove()" aria-label="Schließen">
							<span class="sr-only">Schließen</span>
							<svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
							</svg>
						</button>
					</div>
				{% endfor %}

				{{ form_start(form, { attr: { enctype: 'multipart/form-data', novalidate: 'novalidate', 'data-turbo': 'false', class: 'max-w-2xl' } }) }}
					{{ form_row(form.belongsToRock) }}
					{{ form_row(form.belongsToRoute, { help: 'Optional: Wählen Sie eine Route, wenn das Foto zu einer spezifischen Route gehört.' }) }}
					{{ form_row(form.image, { help: 'Maximale Dateigröße: 10MB. Erlaubte Formate: JPEG, PNG, WebP, GIF' }) }}
					{{ form_row(form.description) }}
					{{ form_row(form.uploaderName) }}
					{{ form_row(form.uploaderEmail, { help: 'Ihre E-Mail wird nicht veröffentlicht und nur für Rückfragen verwendet.' }) }}
					<button type="submit" class="mb-8 mt-2 inline-flex items-center justify-center rounded-md border border-emerald-700 bg-emerald-600 px-4 py-2.5 text-sm font-medium shadow-sm transition-colors hover:bg-emerald-700 focus-visible:outline focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 dark:border-emerald-600 dark:bg-emerald-600 dark:hover:bg-emerald-500 dark:focus-visible:ring-offset-gray-900">
						Foto hochladen
					</button>
				{{ form_end(form) }}
			</section>
		</div>
	</main>
{% endblock %}
