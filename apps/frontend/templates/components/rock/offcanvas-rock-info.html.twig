{% if rocks is not empty %}
	{% set rock = rocks|first %}
	<dialog id="offcanvasRight" class="rock-info-dialog z-[1055]" aria-labelledby="offcanvasRightLabel" aria-modal="true">
		<div class="flex h-full min-h-0 w-full flex-row-reverse">
			<div class="rock-info-dialog__panel flex h-full min-h-0 w-full max-w-full shrink-0 flex-col overflow-y-auto bg-[var(--theme-bg)] text-[var(--theme-text)] shadow-xl sm:w-[min(100vw,24rem)]" onclick="event.stopPropagation()">
				<div class="flex shrink-0 items-center justify-between border-b border-[var(--theme-border)] px-3 py-2">
					<h2 class="m-0 text-lg font-bold text-[var(--theme-text)]" id="offcanvasRightLabel">{{ rock.rockName }}</h2>
					<button type="button" class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md text-[var(--theme-text)] opacity-70 hover:bg-[var(--theme-bg-lighter)] hover:opacity-100 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-[var(--theme-border)]" onclick="document.getElementById('offcanvasRight').close()" aria-label="{{ 'close'|trans({}, 'messages') }}">
						<span class="sr-only">{{ 'close'|trans({}, 'messages') }}</span>
						<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
						</svg>
					</button>
				</div>
				<div class="min-h-0 flex-1 overflow-y-auto">
					{% set hasDescription = (description is defined and description is not null and description|striptags|trim != '') or (rock.rockDescription is defined and rock.rockDescription is not null and rock.rockDescription|striptags|trim != '') %}
					{% set hasAccess = (access is defined and access is not null and access|striptags|trim != '') or (rock.rockAccess is defined and rock.rockAccess is not null and rock.rockAccess|striptags|trim != '') %}
					{% set hasNature = (nature is defined and nature is not null and nature|striptags|trim != '') or (rock.rockNature is defined and rock.rockNature is not null and rock.rockNature|striptags|trim != '') %}
					{% set mithelfenOpenState = mithelfenOpen|default(false) %}
					{% set mithelfenTabState = mithelfenTab|default('content') %}
					<twig:Accordion id="rock-offcanvas-accordion" defaultValue="{{ mithelfenOpenState ? 'improvement' : 'general' }}">
						<twig:Accordion:Item value="general">
							<twig:Accordion:Trigger class="rounded-none border-0 px-5 py-3 text-sm font-semibold text-[var(--theme-text)] hover:bg-[var(--theme-bg-lighter)] hover:no-underline **:data-[slot=accordion-trigger-icon]:text-[var(--theme-text)]">
								<span class="flex min-w-0 flex-1 items-center gap-2 text-left">
									<div class="rock-general-info text-black me-2 dark:text-gray-100"></div>
									<span class="min-w-0 flex-1">{{ 'general.information'|trans }}</span>
								</span>
							</twig:Accordion:Trigger>
							<twig:Accordion:Content class="border-t border-[var(--theme-border)] px-0 pb-3 pt-0">
								<table class="w-full border-collapse text-sm font-medium text-[var(--theme-text)] [&>tbody>tr:last-child]:border-b-0">
									{% if rock.amountRoutes is defined and rock.amountRoutes > 0 %}
										<tr>
											<td colspan="2" class="border-0 px-3 pt-2 align-top">
												{{ include('components/grade-distribution-chart.html.twig', {
													grade_chart_source: rock,
													route_count: rock.amountRoutes,
													aria_label_prefix: rock.rockName ~ '. ',
													wrapper_class: 'max-w-full justify-start',
													include_projects_column: true,
													project_count: rock.amountProjects|default(0)
												}) }}
											</td>
										</tr>
									{% endif %}
									<tr class="border-b border-[var(--theme-border)] odd:bg-[var(--theme-bg-lighter)]/50">
										<td class="px-3 py-2 align-top">{{ 'height'|trans }}:</td>
										<td class="px-3 py-2 align-top">{{ rock.rockHeight }} m</td>
									</tr>
									<tr class="border-b border-[var(--theme-border)] odd:bg-[var(--theme-bg-lighter)]/50">
										<td class="px-3 py-2 align-top">{{ 'orientation'|trans }}:</td>
										<td class="px-3 py-2 align-top">{{ rock.rockOrientation }}</td>
									</tr>
									<tr class="border-b border-[var(--theme-border)] odd:bg-[var(--theme-bg-lighter)]/50">
										<td class="px-3 py-2 align-top">{{ 'sunny'|trans }}:</td>
										<td class="px-3 py-2 align-top">
											{% if rock.rockSunny is same as(true) %}
												{{ 'sunny.property.sunny'|trans }}
											{% elseif rock.rockSunny is same as(false) %}
												{{ 'sunny.property.sun'|trans }}
											{% else %}
												-
											{% endif %}
										</td>
									</tr>
									<tr class="border-b border-[var(--theme-border)] odd:bg-[var(--theme-bg-lighter)]/50">
										<td class="px-3 py-2 align-top">{{ 'child.friendly'|trans }}:</td>
										<td class="px-3 py-2 align-top">
											{% if rock.rockChild == 1 %}
												{{ 'child.friendly.good'|trans }}
											{% else %}
												{{ 'child.friendly.bad'|trans }}
											{% endif %}
										</td>
									</tr>
									<tr class="border-b border-[var(--theme-border)] odd:bg-[var(--theme-bg-lighter)]/50">
										<td class="px-3 py-2 align-top">{{ 'rain.proof'|trans }}:</td>
										<td class="px-3 py-2 align-top">
											{% if rock.rockRain is same as(true) %}
												{{ 'rain.proof.good'|trans }}
											{% elseif rock.rockRain is same as(false) %}
												{{ 'rain.proof.not'|trans }}
											{% else %}
												&mdash;
											{% endif %}
										</td>
									</tr>
									<tr class="border-b border-[var(--theme-border)] odd:bg-[var(--theme-bg-lighter)]/50">
										<td class="px-3 py-2 align-top">{{ 'gps'|trans }}:</td>
										<td class="px-3 py-2 align-top">{{ rock.rockLat }}, {{ rock.rockLng }}</td>
									</tr>
									<tr class="border-b border-[var(--theme-border)] odd:bg-[var(--theme-bg-lighter)]/50">
										<td class="px-3 py-2 align-top">{{ 'show.on.map'|trans }}:</td>
										<td class="px-3 py-2 align-top">
											<a href="https://www.google.com/maps?q={{ rock.rockLat }},{{ rock.rockLng }}" target="_blank" rel="noopener noreferrer" class="text-sky-700 underline decoration-dotted underline-offset-2 hover:text-sky-900 dark:text-sky-400 dark:hover:text-sky-300" aria-label="Open location in Google Maps (opens in new window)"><span class="inline-block -rotate-45" aria-hidden="true">→</span> Google Maps</a>,<br>
											<a href="https://www.openstreetmap.org/?mlat={{ rock.rockLat }}&mlon={{ rock.rockLng }}&zoom=15" target="_blank" rel="noopener noreferrer" class="text-sky-700 underline decoration-dotted underline-offset-2 hover:text-sky-900 dark:text-sky-400 dark:hover:text-sky-300" aria-label="Open location in OpenStreetMap (opens in new window)"><span class="inline-block -rotate-45" aria-hidden="true">→</span> OpenStreetMap</a>
										</td>
									</tr>
									<tr class="border-b border-[var(--theme-border)] odd:bg-[var(--theme-bg-lighter)]/50">
										<td class="px-3 py-2 align-top">{{ 'season'|trans }}:</td>
										<td class="px-3 py-2 align-top">{{ rock.rockSeason }}</td>
									</tr>
									{% if rock.rockZone %}
										<tr class="border-b border-[var(--theme-border)] odd:bg-[var(--theme-bg-lighter)]/50">
											<td class="px-3 py-2 align-top">{{ 'zone'|trans }}:</td>
											<td class="px-3 py-2 align-top">{{ rock.rockZone }}</td>
										</tr>
									{% endif %}
								</table>
							</twig:Accordion:Content>
						</twig:Accordion:Item>
						{% if hasDescription %}
							<twig:Accordion:Item value="description">
								<twig:Accordion:Trigger class="rounded-none border-0 px-5 py-3 text-sm font-semibold text-[var(--theme-text)] hover:bg-[var(--theme-bg-lighter)] hover:no-underline **:data-[slot=accordion-trigger-icon]:text-[var(--theme-text)]">
									<span class="flex min-w-0 flex-1 items-center gap-2 text-left">
										<div class="rock-general-description text-black me-2 dark:text-gray-100"></div>
										<span class="min-w-0 flex-1">{{ 'description'|trans }}</span>
									</span>
								</twig:Accordion:Trigger>
								<twig:Accordion:Content class="border-t border-[var(--theme-border)] px-5 pb-3 pt-2 text-sm leading-relaxed text-[var(--theme-text)] [&_a]:text-sky-700 [&_a]:underline dark:[&_a]:text-sky-400">
									{% if description is defined and description is not null and description|striptags|trim != '' %}
										{{ description|raw }}
									{% else %}
										{{ rock.rockDescription|raw }}
									{% endif %}
								</twig:Accordion:Content>
							</twig:Accordion:Item>
						{% endif %}
						{% if hasAccess %}
							<twig:Accordion:Item value="access">
								<twig:Accordion:Trigger class="rounded-none border-0 px-5 py-3 text-sm font-semibold text-[var(--theme-text)] hover:bg-[var(--theme-bg-lighter)] hover:no-underline **:data-[slot=accordion-trigger-icon]:text-[var(--theme-text)]">
									<span class="flex min-w-0 flex-1 items-center gap-2 text-left">
										<div class="rock-general-access text-black me-2 dark:text-gray-100"></div>
										<span class="min-w-0 flex-1">{{ 'arrival.and.access'|trans }}</span>
									</span>
								</twig:Accordion:Trigger>
								<twig:Accordion:Content class="border-t border-[var(--theme-border)] px-5 pb-3 pt-2 text-sm leading-relaxed text-[var(--theme-text)] [&_a]:text-sky-700 [&_a]:underline dark:[&_a]:text-sky-400">
									{% if access is defined and access is not null and access|striptags|trim != '' %}
										{{ access|raw }}
									{% else %}
										{{ rock.rockAccess|raw }}
									{% endif %}
								</twig:Accordion:Content>
							</twig:Accordion:Item>
						{% endif %}
						<twig:Accordion:Item value="map" id="rockMapDetails">
							<twig:Accordion:Trigger class="rounded-none border-0 px-5 py-3 text-sm font-semibold text-[var(--theme-text)] hover:bg-[var(--theme-bg-lighter)] hover:no-underline **:data-[slot=accordion-trigger-icon]:text-[var(--theme-text)]">
								<span class="flex min-w-0 flex-1 items-center gap-2 text-left">
									<div class="rock-general-map text-black me-2 dark:text-gray-100"></div>
									<span class="min-w-0 flex-1">{{ 'map'|trans }}</span>
								</span>
							</twig:Accordion:Trigger>
							<twig:Accordion:Content class="border-t border-[var(--theme-border)] p-0">
								{{ include('components/map/rock-map.html.twig') }}
							</twig:Accordion:Content>
						</twig:Accordion:Item>
						{% if hasNature %}
							<twig:Accordion:Item value="nature">
								<twig:Accordion:Trigger class="rounded-none border-0 px-5 py-3 text-sm font-semibold text-[var(--theme-text)] hover:bg-[var(--theme-bg-lighter)] hover:no-underline **:data-[slot=accordion-trigger-icon]:text-[var(--theme-text)]">
									<span class="flex min-w-0 flex-1 items-center gap-2 text-left">
										<div class="rock-general-alert text-black me-2 dark:text-gray-100"></div>
										<span class="min-w-0 flex-1">{{ 'climbing.regulations'|trans }}</span>
									</span>
								</twig:Accordion:Trigger>
								<twig:Accordion:Content class="border-t border-[var(--theme-border)] px-5 pb-3 pt-2 text-sm leading-relaxed text-[var(--theme-text)] [&_a]:text-sky-700 [&_a]:underline dark:[&_a]:text-sky-400">
									{% if nature is defined and nature is not null and nature|striptags|trim != '' %}
										{{ nature|raw }}
									{% else %}
										{{ rock.rockNature|raw }}
									{% endif %}
								</twig:Accordion:Content>
							</twig:Accordion:Item>
						{% endif %}
						{% if flowers is defined and flowers is not null %}
							<twig:Accordion:Item value="flowers">
								<twig:Accordion:Trigger class="rounded-none border-0 px-5 py-3 text-sm font-semibold text-[var(--theme-text)] hover:bg-[var(--theme-bg-lighter)] hover:no-underline **:data-[slot=accordion-trigger-icon]:text-[var(--theme-text)]">
									<span class="flex min-w-0 flex-1 items-center gap-2 text-left">
										<div class="rock-general-flowers text-black me-2 dark:text-gray-100"></div>
										<span class="min-w-0 flex-1">{{ 'plants'|trans }}</span>
									</span>
								</twig:Accordion:Trigger>
								<twig:Accordion:Content class="border-t border-[var(--theme-border)] px-5 pb-3 pt-2 text-sm leading-relaxed text-[var(--theme-text)] [&_a]:text-sky-700 [&_a]:underline dark:[&_a]:text-sky-400">
									{{ flowers|raw }}
								</twig:Accordion:Content>
							</twig:Accordion:Item>
						{% endif %}
						{% if jsonData %}
							<twig:Accordion:Item value="gallery">
								<twig:Accordion:Trigger class="rounded-none border-0 px-5 py-3 text-sm font-semibold text-[var(--theme-text)] hover:bg-[var(--theme-bg-lighter)] hover:no-underline **:data-[slot=accordion-trigger-icon]:text-[var(--theme-text)]">
									<span class="flex min-w-0 flex-1 items-center gap-2 text-left">
										<div class="rock-general-images text-black me-2 dark:text-gray-100"></div>
										<span class="min-w-0 flex-1">{{ 'images'|trans }}</span>
									</span>
								</twig:Accordion:Trigger>
								<twig:Accordion:Content class="border-t border-[var(--theme-border)] px-2 pb-3 pt-2">
									<div class="mx-0 grid grid-cols-3 gap-1 md:grid-cols-4" data-controller="off-canvas-gallery">
										{% for data in jsonData %}
											<div class="mb-1">
												<a class="lg-item block" data-target="lg-item" data-src="{{ data.src }}" data-srcset="{{ data.srcset }}" href="{{ data.src }}" role="button">
													<img src="{{ data.thumb }}" class="mb-1 w-full shadow-md" alt="{{ data.subHtml }}" loading="lazy">
												</a>
											</div>
										{% endfor %}
									</div>
								</twig:Accordion:Content>
							</twig:Accordion:Item>
						{% endif %}
						<twig:Accordion:Item value="symbols">
							<twig:Accordion:Trigger class="rounded-none border-0 px-5 py-3 text-sm font-semibold text-[var(--theme-text)] hover:bg-[var(--theme-bg-lighter)] hover:no-underline **:data-[slot=accordion-trigger-icon]:text-[var(--theme-text)]">
								<span class="flex min-w-0 flex-1 items-center gap-2 text-left">
									<div class="rock-general-signs text-black me-2 dark:text-gray-100"></div>
									<span class="min-w-0 flex-1">{{ 'explanation.symbols'|trans }}</span>
								</span>
							</twig:Accordion:Trigger>
							<twig:Accordion:Content class="border-t border-[var(--theme-border)] px-2 pb-3 pt-2">
								<div class="mx-0">
									<table class="w-full border-collapse text-sm font-medium text-[var(--theme-text)] [&>tbody>tr:last-child]:border-b-0">
										<tr class="border-b border-[var(--theme-border)]">
											<td class="px-3 py-2  align-middle">
												<div class="star d-inline-block"></div>
											</td>
											<td class="px-3 py-2  align-middle">{{ 'nice.route'|trans }}</td>
										</tr>
										<tr class="border-b border-[var(--theme-border)]">
											<td class="px-3 py-2  align-middle">
												<div class="flex">
													<div class="star d-inline-block"></div>
													<div class="star d-inline-block"></div>
												</div>
											</td>
											<td class="px-3 py-2  align-middle">{{ 'very.nice.route'|trans }}</td>
										</tr>
										<tr class="border-b border-[var(--theme-border)]">
											<td class="px-3 py-2  align-middle">
												<div class="flex">
													<div class="star"></div>
													<div class="star"></div>
													<div class="star"></div>
												</div>
											</td>
											<td class="px-3 py-2  align-middle">{{ 'dream.route'|trans }}</td>
										</tr>
										<tr class="border-b border-[var(--theme-border)]">
											<td class="px-3 py-2  align-middle">
												<div class="trash"></div>
											</td>
											<td class="px-3 py-2  align-middle">{{ 'shit.route'|trans }}</td>
										</tr>
										<tr class="border-b border-[var(--theme-border)]">
											<td class="px-3 py-2  align-middle">
												<div class="exclamation d-inline-block"></div>
											</td>
											<td class="px-3 py-2  align-middle">{{ 'bad.routeprotection'|trans }}</td>
										</tr>
										<tr class="border-b border-[var(--theme-border)]">
											<td class="px-3 py-2  align-middle">
												<div class="skull d-inline-block"></div>
											</td>
											<td class="px-3 py-2  align-middle">{{ 'dangerous.routeprotection'|trans }}</td>
										</tr>
										<tr class="border-b border-[var(--theme-border)]">
											<td class="px-3 py-2  align-middle">
												<div class="loose-rock d-inline-block"></div>
											</td>
											<td class="px-3 py-2  align-middle">{{ 'rock.quality'|trans }}</td>
										</tr>
										<tr class="border-b border-[var(--theme-border)]">
											<td class="px-3 py-2  align-middle">
												<div class="multi-pitch d-inline-block"></div>
											</td>
											<td class="px-3 py-2  align-middle">{{ 'multi.pitch'|trans }}</td>
										</tr>
										<tr class="border-b border-[var(--theme-border)]">
											<td class="px-3 py-2  align-middle">
												<div class="crack-climbing d-inline-block"></div>
											</td>
											<td class="px-3 py-2  align-middle">{{ 'crack.climbing'|trans }}</td>
										</tr>
									</table>
								</div>
							</twig:Accordion:Content>
						</twig:Accordion:Item>
						<twig:Accordion:Item value="improvement">
							<twig:Accordion:Trigger class="rounded-none border-0 px-5 py-3 text-sm font-semibold text-[var(--theme-text)] hover:bg-[var(--theme-bg-lighter)] hover:no-underline **:data-[slot=accordion-trigger-icon]:text-[var(--theme-text)]">
								<span class="flex min-w-0 flex-1 items-center gap-2 text-left">
									<div class="rock-general-improvement text-black me-2 dark:text-gray-100"></div>
									<span class="min-w-0 flex-1">{{ 'rock_improvement.title'|trans }}</span>
								</span>
							</twig:Accordion:Trigger>
							<twig:Accordion:Content class="border-t border-[var(--theme-border)] px-3 pb-4 pt-2">
								{% if improvementForm is defined and improvementForm is not null and galleryUploadForm is defined and galleryUploadForm is not null %}
									{% form_theme improvementForm 'form/tailwind_form_layout.html.twig' %}
									{% form_theme galleryUploadForm 'form/tailwind_form_layout.html.twig' %}
									{% set mithelfenDefaultTab = mithelfenTabState %}
									{% for message in app.flashes('mithelfen_success') %}
										<div data-mithelfen-success-alert class="mb-3 rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-900 dark:border-emerald-800 dark:bg-emerald-950/30 dark:text-emerald-200" role="status">{{ message }}</div>
									{% endfor %}
									<script>
										(() => {
											const alerts = document.querySelectorAll('[data-mithelfen-success-alert]');
											if (!alerts.length) {
												return;
											}
											window.setTimeout(() => {
												alerts.forEach((alert) => alert.remove());
											}, 2000);
										})();
									</script>
									{% for message in app.flashes('mithelfen_error') %}
										<div class="mb-3 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-900 dark:border-red-800 dark:bg-red-950/30 dark:text-red-200" role="alert">{{ message }}</div>
									{% endfor %}
									<twig:Tabs defaultValue="{{ mithelfenDefaultTab }}" class="mb-1">
										<twig:Tabs:List variant="default" class="mb-3 grid w-full grid-cols-2">
											<twig:Tabs:Trigger value="content">{{ 'rock_improvement.tab.content'|trans }}</twig:Tabs:Trigger>
											<twig:Tabs:Trigger value="gallery">{{ 'rock_improvement.tab.gallery'|trans }}</twig:Tabs:Trigger>
										</twig:Tabs:List>

										<twig:Tabs:Content value="content">
											<p class="mb-3 text-sm text-gray-600 dark:text-gray-400">{{ 'rock_improvement.intro'|trans({ '%rock_name%': rock.rockName }) }}</p>
											{{ form_start(improvementForm, { action: path(app.request.attributes.get('_route'), { areaSlug: areaSlug, slug: slug }), attr: { class: 'max-w-full text-sm', novalidate: 'novalidate' } }) }}
											{{ form_row(improvementForm.rockName) }}
											{{ form_row(improvementForm.name) }}
											{{ form_row(improvementForm.email) }}
											{{ form_row(improvementForm.routeName) }}
											{{ form_row(improvementForm.grade) }}
											{{ form_row(improvementForm.firstAscent) }}
											{{ form_row(improvementForm.comment) }}
											<button type="submit" class="mt-2 inline-flex items-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium shadow-sm hover:bg-emerald-700 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-gray-900">{{ 'rock_improvement.submit'|trans }}</button>
											{{ form_end(improvementForm) }}
										</twig:Tabs:Content>

										<twig:Tabs:Content value="gallery">
											<p class="mb-3 text-sm text-gray-600 dark:text-gray-400">{{ 'rock_improvement.gallery_intro'|trans({ '%rock_name%': rock.rockName }) }}</p>
											{{ form_start(galleryUploadForm, { action: path(app.request.attributes.get('_route'), { areaSlug: areaSlug, slug: slug }), attr: { class: 'max-w-full text-sm', novalidate: 'novalidate', enctype: 'multipart/form-data' } }) }}
											{{ form_row(galleryUploadForm.rockName) }}
											{{ form_row(galleryUploadForm.routeId) }}
											{{ form_row(galleryUploadForm.name) }}
											{{ form_row(galleryUploadForm.email) }}
											{{ form_row(galleryUploadForm.photographer) }}
											{{ form_row(galleryUploadForm.image, { help: 'rock_improvement.help.image'|trans }) }}
											{{ form_row(galleryUploadForm.comment) }}
											<button type="submit" class="mt-2 inline-flex items-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium shadow-sm hover:bg-emerald-700 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-gray-900">{{ 'rock_improvement.submit_gallery'|trans }}</button>
											{{ form_end(galleryUploadForm) }}
										</twig:Tabs:Content>
									</twig:Tabs>
								{% endif %}
							</twig:Accordion:Content>
						</twig:Accordion:Item>
					</twig:Accordion>
				</div>
			</div>
			<button type="button" class="min-h-0 min-w-0 flex-1 cursor-default border-0 bg-black/40 p-0" aria-label="{{ 'close'|trans({}, 'messages') }}" onclick="document.getElementById('offcanvasRight').close()"></button>
		</div>
	</dialog>
	{% if mithelfenOpenState %}
		<script>
			(() => {
				const dialog = document.getElementById('offcanvasRight');
				if (!dialog || dialog.open) {
					return;
				}
				try {
					dialog.showModal();
				} catch (e) {
					/* ignore if dialog cannot be opened in current browser state */
				}
			})();
		</script>
	{% endif %}
{% endif %}
