{% set url = 'https://www.munichclimbs.de/uploads/areas/' %}
{% set marker = [] %}
{% for area in getAreasInformation() %}
    {% set popupBody = include('partials/_areaCardBody.html.twig', { area: area, ulClass: 'mt-2', showTravelTime: true }) %}
    {% set areaName = '<div class="main-map-popup-card">' ~
        '<div class="main-map-popup-image-wrap">' ~
        '<picture><source srcset="' ~ url ~ area.image ~ '@1x.webp 1x, ' ~ url ~ area.image ~ '@2x.webp 2x, ' ~ url ~ area.image ~ '@3x.webp 3x" type="image/webp">' ~
        '<img class="main-map-popup-image" src="' ~ url ~ area.image ~ '.webp" alt="Klettergebiet ' ~ area.name|e('html_attr') ~ '" loading="lazy" decoding="async">' ~
        '</picture>' ~
        '<div class="main-map-popup-header">' ~
        '<a href="' ~ path('show_rocks', { slug: area.slug }) ~ '" class="main-map-popup-link">' ~ area.name|e('html') ~ '</a>' ~
        '<button type="button" class="main-map-popup-close" onclick="this.closest(\'.leaflet-popup\').querySelector(\'.leaflet-popup-close-button\').click()" aria-label="Schließen"><span>&times;</span></button>' ~
        '</div></div>' ~
        '<div class="main-map-popup-body">' ~ popupBody ~ '</div></div>' %}
    {% set areaImage = '' %}
    {% set marker = marker|merge([{
        'lat': area.lat,
        'lng': area.lng,
        'popup': areaName,
        'image': areaImage,
        'travelTimeMinutes': area.travelTimeMinutes|default(null)
    }]) %}
{% endfor %}

<div 
    class="main-map-container d-flex flex-column h-100"
    data-controller="main-map" 
    data-main-map-markers-value="{{ marker|json_encode|e('html_attr') }}"
>
    <div class="main-map-filters flex-shrink-0 py-2 px-3 gap-2 d-flex flex-wrap align-items-center" data-main-map-target="filters">
        <span class="small text-muted">Fahrtzeit ab München:</span>
        <button type="button" class="btn btn-outline-secondary btn-sm active" data-main-map-target="filterBtn" data-range="all">Alle</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" data-main-map-target="filterBtn" data-range="0-60">&lt; 1 h</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" data-main-map-target="filterBtn" data-range="60-90">1 – 1,5 h</button>
        <button type="button" class="btn btn-outline-secondary btn-sm" data-main-map-target="filterBtn" data-range="120">> 2 h</button>
    </div>
    <div class="flex-grow-1 min-h-0" style="min-height: 400px;" data-main-map-target="map"></div>
</div>
