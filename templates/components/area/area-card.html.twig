{# Reusable area card. Pass `area` and optional `link` (href for the card). Omit `link` for a non-clickable card. #}
{% set url = url|default('https://www.munichclimbs.de/uploads/areas/') %}
{% if link is defined and link is not empty %}
	<a class="block no-underline text-gray-900 dark:text-gray-100 focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-black" href="{{ link }}" title="Klettergebiet {{ area.name }}">
{% endif %}
<div class="mb-4 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-md dark:border-gray-700 dark:bg-black">
	<div class="grid grid-cols-1 gap-0 md:grid-cols-2">
		<div class="relative min-w-0">
			{% include 'components/area/lazy-load-images.html.twig' with {
				'area': area,
				'url': url,
				'media': {
					'(min-width: 1200px)': url ~ area.image,
					'(min-width: 800px)': url ~ area.image,
				},
			} %}
		</div>
		<div class="min-w-0">
			<div class="flex h-full min-h-0 flex-col p-3">
				<h2 class="h5 card-title mb-0 fw-normal hidden md:block">{{ area.name }}</h2>
				{{ include('components/area/area-card-body.html.twig', { area: area, chart_summary_include_rocks: chart_summary_include_rocks|default(false) }) }}
			</div>
		</div>
	</div>
</div>
{% if link is defined and link is not empty %}
	</a>
{% endif %}
