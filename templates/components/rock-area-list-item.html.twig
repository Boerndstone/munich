{# Single rock row on the area "rocks" listing. Expects: rock, areaName, currentDate #}
<div class="w-full rock-item {% if (rock.banned == 1 and currentDate < 181) or (rock.banned == 2 and currentDate < 212) %}banned{% endif %}" data-child-friendly="{{ rock.rockChild == 1 ? 'true' : 'false' }}" data-rock-sunny="{{ rock.rockSunny ? 'true' : 'false' }}" data-rock-rain="{{ rock.rockRain ? 'true' : 'false' }}" data-rock-train="{{ rock.rockTrain == 1 ? 'true' : 'false' }}" data-rock-bike="{{ (rock.rockBike is defined and rock.rockBike == 1) ? 'true' : 'false' }}" data-route-grades="{{ rock.routeGrades|default('')|e('html_attr') }}">
	<a href="{{ rock_path(rock.areaSlug, rock.rockSlug) }}" class="group block rounded-lg text-black no-underline outline-hidden ring-offset-2 ring-offset-white transition-none focus-visible:ring-2 focus-visible:ring-gray-500 dark:text-white dark:ring-offset-black dark:focus-visible:ring-gray-400">
		<div class="rock-item-card mb-2 flex overflow-hidden rounded-lg border border-gray-200 bg-white shadow-md transition-[box-shadow,border-color,background-color] duration-200 ease-out group-hover:border-gray-300 group-hover:bg-neutral-50 group-hover:shadow-lg dark:border-gray-700 dark:bg-black dark:group-hover:border-gray-600 dark:group-hover:bg-neutral-950/80">
			<div class="relative w-[75px] shrink-0 self-stretch bg-gray-200 dark:bg-gray-800">
				<div class="absolute inset-0 overflow-hidden">
					{% if rock.previewImage is defined and rock.previewImage is not null %}
						<picture class="absolute inset-0 block">
							<source type="image/webp" srcset="https://www.munichclimbs.de/build/images/rock/{{ rock.previewImage }}.webp, https://www.munichclimbs.de/build/images/rock/{{ rock.previewImage }}@2x.webp 2x, https://www.munichclimbs.de/build/images/rock/{{ rock.previewImage }}@3x.webp 3x">
							<img src="https://www.munichclimbs.de/build/images/rock/{{ rock.previewImage }}.webp" alt="Klettergebiet, {{ areaName}}, Fels: {{ rock.rockName }}" title="Klettergebiet, {{ areaName }}, Fels: {{ rock.rockName }}" loading="lazy" decoding="async" fetchpriority="low" class="h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.04]">
						</picture>
					{% else %}
						<div class="flex h-full min-h-[3.5rem] w-full items-center justify-center">
							<svg role="img" aria-label="Klettergebiet, {{ areaName}}, Fels: {{ rock.rockName }}" title="Klettergebiet, {{ areaName }}, Fels: {{ rock.rockName }}" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewbox="0 0 24 24" class="text-gray-600 dark:text-gray-400">
								<title>Klettergebiet, {{ areaName}}, Fels: {{ rock.rockName }}</title>
								<path fill="currentColor" d="M23 18H1l7.25-9.67l2 2.67L14 6zm-11.5-5.33L14 16h5l-5-6.67zM5 16h6.5l-3.25-4.33z"/>
							</svg>
						</div>
					{% endif %}
				</div>
				{% if (rock.banned == 1 and currentDate < 181) or (rock.banned == 2 and currentDate < 212) %}
					{% set ban_until = rock.banned == 1
						? date(date("now")|date("Y") ~ "-01-01")|date_modify("+180 days")|date('d.m.')
						: date(date("now")|date("Y") ~ "-01-01")|date_modify("+211 days")|date('d.m.')
					%}
					{# Vertical band on the left: horizontal copy rotated 90° (reads LTR along the strip) #}
					<div class="pointer-events-none absolute top-5 left-2 rotate-[-45deg] z-10 flex w-9 items-center justify-center" aria-hidden="true">
						<span class="flex items-center gap-1 whitespace-nowrap bg-red-600 px-2 py-0.5 text-center text-[10px] leading-tight tracking-tight text-white shadow-md "><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2c5.5 0 10 4.5 10 10s-4.5 10-10 10S2 17.5 2 12S6.5 2 12 2m0 2c-1.9 0-3.6.6-4.9 1.7l11.2 11.2c1-1.4 1.7-3.1 1.7-4.9c0-4.4-3.6-8-8-8m4.9 14.3L5.7 7.1C4.6 8.4 4 10.1 4 12c0 4.4 3.6 8 8 8c1.9 0 3.6-.6 4.9-1.7"/></svg> bis: {{ ban_until }}</span>
					</div>
				{% endif %}
			</div>
			<div class="flex min-w-0 flex-1 flex-col gap-1.5 px-3 py-2">
				<div class="min-w-0 flex items-center justify-between">
					<h2 class="mb-0 min-w-0 max-w-[150px] truncate text-base font-normal leading-tight lg:max-w-none">{{ rock.rockName }}</h2>
					<div class="mt-0.5 flex flex-wrap items-center gap-1 text-sm text-gray-800 dark:text-gray-200">
						<p class="mb-0">{{ rock.rockHeight }} m</p>
						<div class="h-3.5 w-px shrink-0 bg-gray-400 dark:bg-gray-600" aria-hidden="true"></div>
						<p class="mb-0">{{ rock.rockOrientation }}</p>
					</div>
				</div>
				<div class="min-w-0 w-full">
					{{ include('components/rock-list-grade-strip.html.twig', {
						rock: rock,
						aria_label_prefix: 'Klettergebiet ' ~ areaName ~ ', Fels ' ~ rock.rockName ~ '. ',
						include_projects_column: true,
						project_count: rock.amountProjects|default(0)
					}) }}
				</div>
			</div>
		</div>
	</a>
</div>
