{# Tailwind-styled rows/widgets; extends Symfony div layout via use + parent(). #}
{% use "form_div_layout.html.twig" %}

{%- block form_row_render -%}
	{%- set row_merged = row_attr|merge({ class: (row_attr.class|default('') ~ ' mb-5')|trim }) -%}
	<div{% with { attr: row_merged } %}{{ block('attributes') }}{% endwith %}>
		{{- form_label(form) -}}
		{{- form_errors(form) -}}
		{{- form_widget(form, widget_attr) -}}
		{{- form_help(form) -}}
	</div>
{%- endblock form_row_render -%}

{%- block form_label -%}
	{%- if label is not same as(false) -%}
		{%- if not compound -%}
			{%- set label_attr = label_attr|merge({ for: id }) -%}
		{%- endif -%}
		{%- set label_classes = 'mb-1 block text-sm font-medium text-gray-900 dark:text-gray-100' -%}
		{%- if required -%}
			{%- set label_classes = label_classes ~ " after:ms-0.5 after:text-red-500 after:content-['*']" -%}
		{%- endif -%}
		{%- set label_attr = label_attr|merge({ class: (label_attr.class|default('') ~ ' ' ~ label_classes)|trim }) -%}
		<{{ element|default('label') }}{% if label_attr %}{% with { attr: label_attr } %}{{ block('attributes') }}{% endwith %}{% endif %}>
			{{- block('form_label_content') -}}
		</{{ element|default('label') }}>
	{%- endif -%}
{%- endblock form_label -%}

{%- block widget_attributes -%}
	{%- set base_class = 'mt-1 block w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/30 disabled:cursor-not-allowed disabled:opacity-60 dark:border-gray-600 dark:bg-gray-900 dark:text-gray-100 dark:placeholder:text-gray-500 dark:focus:border-sky-400 dark:focus:ring-sky-400/30' -%}
	{%- if type|default('') == 'file' -%}
		{%- set base_class = base_class ~ ' cursor-pointer file:me-3 file:cursor-pointer file:rounded-md file:border-0 file:bg-sky-600 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-white hover:file:bg-sky-700' -%}
	{%- endif -%}
	{%- set attr = attr|merge({ class: (attr.class|default('') ~ ' ' ~ base_class)|trim }) -%}
	{{- parent() -}}
{%- endblock widget_attributes -%}

{%- block form_help -%}
	{%- if help -%}
		{%- set help_attr = help_attr|merge({ class: (help_attr.class|default('') ~ ' mt-1 block text-sm text-gray-500 dark:text-gray-400')|trim }) -%}
		<div id="{{ id }}_help"{% with { attr: help_attr } %}{{ block('attributes') }}{% endwith %}>
			{{- block('form_help_content') -}}
		</div>
	{%- endif -%}
{%- endblock form_help -%}

{%- block form_errors -%}
	{%- if errors|length > 0 -%}
		<ul class="mt-1 list-none space-y-1 text-sm text-red-600 dark:text-red-400" role="list">
			{%- for error in errors -%}
				<li id="{{ id ~ '_error' ~ loop.index }}">{{ error.message }}</li>
			{%- endfor -%}
		</ul>
	{%- endif -%}
{%- endblock form_errors -%}
