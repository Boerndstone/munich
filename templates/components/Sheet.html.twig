{# Local Shadcn-style Sheet (Symfony UX Shadcn kit has Dialog but no Sheet yet: https://ux.symfony.com/toolkit/kits/shadcn ). #}
{# @prop id string HTML id for the `<dialog>` (e.g. `navOffcanvas`) #}
{# @prop open boolean Whether the sheet is open on first paint. Defaults to `false` #}
{# @block content Typically `Sheet:Content` plus toolbar with `Sheet:Trigger` #}
{%- props id, open = false -%}

<div
	class="{{ ('contents ' ~ attributes.render('class'))|tailwind_merge }}"
	{{ attributes.defaults({
		'data-controller': 'sheet',
		'data-sheet-open-value': open,
	}) }}
>
	{%- block content %}{% endblock -%}
</div>
